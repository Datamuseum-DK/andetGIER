Demonstration program
_b_e_g_i_n
writetext(|<<
    We compare the built-in standard function ln with the integral of 1/x

 p        ln(p)       Integral    ln(p)-Integral
|>);
typechar;
_b_e_g_i_n _i_n_t_e_g_e_r i; _r_e_a_l x, arg, log;
_r_e_a_l _p_r_o_c_e_d_u_r_e Simps(F,x,a,b,delta,V); _v_a_l_u_e a,b,delta,V; _r_e_a_l F,x,a,b,
delta,V;
_b_e_g_i_n _i_n_t_e_g_e_r n,k; _r_e_a_l h,J, I;
      V := (b-a)*V; n := 1; h := (b-a)/2;
      x := a; J := F; x := b; J := (J+F)*h;
J1:   b := 0; _f_o_r k := 1 _s_t_e_p 1 _u_n_t_i_l n _d_o
                  _b_e_g_i_n x := (2*k - 1)*h + a; b := b + F _e_n_d;
      I := 4 * h * b + J;
      _i_f abs(V) * delta < abs(I - V) _t_h_e_n
           _b_e_g_i_n V := I; J := (I+J)/4; n := 2*n; h := h/2; _g_o_ _t_o J1 _e_n_d;
      Simps := I/3
_e_n_d Simps;

_f_o_r i := 80 _s_t_e_p 20 _u_n_t_i_l 200 _d_o
    _b_e_g_i_n arg := i/100;
        writecr; write(|<d.dd|>, arg);
	log := Simps(1/x, x, 1, arg, '-7, 1000);
	write(|<-ddd.ddddddddd|>, ln(arg), log, ln(arg) - log)
    _e_n_d
_e_n_d;
writetext(|<<

    Automatic administration of drum track transfers
    i := 650 _s_t_e_p 10 _u_n_t_i_l 700
|>);
typechar;
_b_e_g_i_n _i_n_t_e_g_e_r i, j;
 _f_o_r i := 650 _s_t_e_p 10 _u_n_t_i_l 700 _d_o
    _b_e_g_i_n writecr; write(|<dddd|>,i);
        _b_e_g_i_n _a_r_r_a_y a[1:i];
	_f_o_r j := 1 _s_t_e_p 1 _u_n_t_i_l i _d_o a[j] := j + sin(j) - exp(-j)
	_e_n_d
    _e_n_d
_e_n_d;
writetext(|<<

     Recursive sum-procedure, 50 to 65 addends, 2*i
|>);
typechar;

_b_e_g_i_n _i_n_t_e_g_e_r k, i;
_r_e_a_l _p_r_o_c_e_d_u_r_e SIGMA(p, q, r, f); _v_a_l_u_e q, r; _i_n_t_e_g_e_r p, q, r;
    _r_e_a_l f;
    _b_e_g_i_n p := q;
    SIGMA := _i_f q>r _t_h_e_n 0 _e_l_s_e f + SIGMA(p, q+1, r, f)
    _e_n_d;
_f_o_r k := 50 _s_t_e_p 1 _u_n_t_i_l 65 _d_o
    _b_e_g_i_n writecr;
          write(|<ddd|>,k);
	  write(|<ddddddd|>, SIGMA(i, 1, k, 2*i))
    _e_n_d
_e_n_d;

writetext(|<<

    And a very complicated prime-calculation
    i  Prime number i
|>);
typechar;
_b_e_g_i_n _i_n_t_e_g_e_r m, P, I, A, Z;
_r_e_a_l _p_r_o_c_e_d_u_r_e GPS(II,N,ZZ,V); _r_e_a_l II,N,ZZ,V;
_b_e_g_i_n _f_o_r  II:= 1 _s_t_e_p 1 _u_n_t_i_l N _d_o ZZ := V;
      GPS := 1
_e_n_d;

_f_o_r m := 1 _s_t_e_p 1 _u_n_t_i_l 10 _d_o
    _b_e_g_i_n I := GPS(I,_i_f I=0 _t_h_e_n -1.0 _e_l_s_e I,P,_i_f I=1 _t_h_e_n 1.0 _e_l_s_e
             _i_f GPS(A,I,Z,_i_f A=1 _t_h_e_n 1 _e_l_s_e
	     _i_f entier(A) * (entier(I)_:entier(A))=entier(I)&A<I
	     _t_h_e_n 0 _e_l_s_e Z) = Z _t_h_e_n
	     (_i_f P<m _t_h_e_n P+1 _e_l_s_e I * GPS(A,1,I,-1)) _e_l_s_e P);
	   writecr;
	    write(|<ddddd|>, m, P)
    _e_n_d
_e_n_d;
_e_n_d of the demonstration program;

