algol<
Pythagoræiske primtal
_b_e_g_i_n
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e primtal(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r test, max;
      max := sqrt(n)+1;
      primtal := _f_a_l_s_e;
      _f_o_r test := 3 _s_t_e_p 2 _u_n_t_i_l max _d_o
      _i_f n _m_o_d test=0 _t_h_e_n _g_o_t_o ej primtal;
      primtal := _t_r_u_e;
ej primtal:
   _e_n_d primtal;
   _p_r_o_c_e_d_u_r_e trekant(c);
   _v_a_l_u_e c;
   _i_n_t_e_g_e_r c;
   _b_e_g_i_n
      _i_n_t_e_g_e_r a,b;
      _f_o_r a:=1 _s_t_e_p 1 _u_n_t_i_l c _d_o
      _f_o_r b:=a _s_t_e_p 1 _u_n_t_i_l c _d_o
      _b_e_g_i_n
         _i_f a*a+b*b=c*c _t_h_e_n
	 _b_e_g_i_n
	    writecr;
	    write(|<ddddddd|>,a,b,c)
	 _e_n_d
      _e_n_d
   _e_n_d trekant;
   _i_n_t_e_g_e_r n,c;
   select(16);
   _f_o_r n:=1 _s_t_e_p 1 _u_n_t_i_l 25 _d_o
   _b_e_g_i_n
      c := 4*n+1;
      _i_f primtal(c) _t_h_e_n trekant(c)
   _e_n_d for n
_e_n_d;
t<

