   _p_r_o_c_e_d_u_r_e sorter(lager,nr,a,fra,til);
   _v_a_l_u_e nr,fra,til;
   _i_n_t_e_g_e_r nr,fra,til;
   _i_n_t_e_g_e_r _a_r_r_a_y a;
   _i_n_t_e_g_e_r _a_r_r_a_y lager;
   _b_e_g_i_n
      _i_n_t_e_g_e_r l,l1,l2,sl1,sl2,n1,n2,step,diff;
      _i_n_t_e_g_e_r _a_r_r_a_y b[fra:til];
      _b_o_o_l_e_a_n i a;
      i a := _t_r_u_e;
      _f_o_r step:=1,2*step _w_h_i_l_e step < til - fra +1 _d_o
      _b_e_g_i_n
         l:=fra-1;
	 _i_f i a _t_h_e_n
	 _b_e_g_i_n
	    _f_o_r l1:=l+1 _w_h_i_l_e l<til _d_o
	    _b_e_g_i_n
	       sl1:=l+step;
	       l2:=sl1+1;
	       sl2:=sl1+step;
	       _i_f sl1>til _t_h_e_n sl1:=sl2:=til
	       _e_l_s_e _i_f sl2>til _t_h_e_n sl2:=til;
	       diff:=sl2-sl1;
	       _f_o_r l:=l+1 _w_h_i_l_e l1_<sl1&l2_<sl2 _d_o
	       _b_e_g_i_n
	          n1 := a[l1];
		  n2 := a[l2];
		  _i_f lager[[n1,nr]_<lager[n2,nr] _t_h_e_n
		  _b_e_g_i_n
		     b[l]:=n1;
		     l1:=l1+1
		  _e_n_d
		  _e_l_s_e
		  _b_e_g_i_n
		     b[l]:=n2;
		     l2:=l2+1
		  _e_n_d
	       _e_n_d for l:= _f_o_r;
	       _i_f l1_<sl1 _t_h_e_n
	       _b_e_g_i_n
	          _f_o_r l:=1 _s_t_e_p 1 _u_n_t_i_l sl2 _d_o
		  _b_e_g_i_n
		     b[l]:=a[l-diff]
		  _e_n_d _f_o_r
	       _e_n_d
	       _e_l_s_e
	       _f_o_r l:=1 _s_t_e_p 1 _u_n_t_i_l sl2 _d_o
	       _b_e_g_i_n
	          b[l]:=a[l]
	       _e_n_d _f_o_r;
	       l:=sl2
	    _e_n_d for l1:=
	 _e_n_d if i a
	 _e_l_s_e
	 _b_e_g_i_n
	    _c_o_m_m_e_n_t det samme med a og b byttet om;
	    _f_o_r l1:=l+1 _w_h_i_l_e l<til _d_o
	    _b_e_g_i_n
	       sl1:=l+step;
	       l2:=sl1+1;
	       sl2:=sl1+step;
	       _i_f sl1>til _t_h_e_n sl1:=sl2:=til
	       _e_l_s_e _i_f sl2>til _t_h_e_n sl2:=til;
	       diff := sl2-sl1;
	       _f_o_r l:=l+1 _w_h_i_l_e l1_<sl1&l2_<sl2 _d_o
	       _b_e_g_i_n
	          n1:=b[l1];
		  n2:=b[l2];
		  _i_f lager[n1,nr]_<lager[n2,nr] _t_h_e_n
		  _b_e_g_i_n
		     a[l]:=n1;
		     l1:=l1+1
		  _e_n_d
		  _e_l_s_e
		  _b_e_g_i_n
		     a[l]:=n2;
		     l2:=l2+1
		  _e_n_d
	       _e_n_d for l:= _f_o_r;
	       _i_f l1_<sl1 _t_h_e_n
	       _b_e_g_i_n
	          _f_o_r l:=1 _s_t_e_p 1 _u_n_t_i_l sl2 _d_o
		  _b_e_g_i_n
		     a[l]:=b[l-diff]
		  _e_n_d _f_o_r
	       _e_n_d
	       _e_l_s_e
	       _f_o_r l:=1 _s_t_e_p 1 _u_n_t_i_l sl2 _d_o
	       _b_e_g_i_n
	          a[l]:=b[l]
	       _e_n_d _f_o_r;
	       l:=sl2
	    _e_n_d for l1:=
	 _e_n_d if -,i a;
	 i a:=-,i a
      _e_n_d for step:=;
      _i_f -,i a _t_h_e_n
      _b_e_g_i_n
         _f_o_r l:=fra _s_t_e_p 1 _u_n_t_i_l til _d_o a[l]:=b[l]
      _e_n_d
   _e_n_d procedure sorter;


      

