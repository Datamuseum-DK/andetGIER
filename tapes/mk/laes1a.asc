algol,_n<
_b_e_g_i_n
   _r_e_a_l sum,sum2,diff,maxdiff,a,worst;
   _i_n_t_e_g_e_r track,n,FREE,maxtrack,maxn;
   _a_r_r_a_y A[0:39];
   select(16);
   where(|<<free|>,FREE);
   track:=1;
   sum:=0;
   sum2:=0;
   worst:=0;
   get(A, FREE, track);
   n:=0;
   maxdiff:=0;
   maxtrack:=0;
   maxn:=0;
loop: a:=read real;
   _i_f n=40 _t_h_e_n
   _b_e_g_i_n
      track:=track+1;
      get(A, FREE, track);
      n:=0
   _e_n_d new track;
   diff:=abs(a-A[n]);
   _i_f diff>maxdiff _t_h_e_n
   _b_e_g_i_n
      maxdiff:=diff;
      maxtrack:=track;
      maxn:=n;
      worst:=A[n]
   _e_n_d new maxdiff;
   sum:=sum+a;
   sum2:=sum2+A[n];
   n:=n+1;
   _i_f char=27 _t_h_e_n _g_o_t_o loop;
   writecr;
   writeinteger(|<p|>,char);
   writecr;
   write(|<  -d.ddd ddd ddd'-dd|>,sum,sum2);
   writecr;
   write(|<  -d.ddd ddd ddd'-dd|>,worst,maxdiff);
   writecr;
   write(|< ddddd|>,maxtrack,maxn)
_e_n_d;
t<

