   _b_o_o_l_e_a_n location;
   select(17);
   location := _b_o_o_l_e_a_n |<<Křbenhavns Observatorium|>;
   latitude := 55.6867;
   longitude := -12.5792;
   location := _b_o_o_l_e_a_n |<<Pilehřjvej 7|>;
   latitude := 55.7606;
   longitude := -12.4832;
   location := _b_o_o_l_e_a_n |<<Ilulissat|>;
