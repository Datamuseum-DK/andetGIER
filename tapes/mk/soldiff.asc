   location := _b_o_o_l_e_a_n |<<Solřje Strandvej 18|>;
   latitude := 55.119399;
   longitude := -11.720632;
   location := _b_o_o_l_e_a_n |<<Gamle Carlsberg Vej 10|>;
   latitude := 55.6658;
