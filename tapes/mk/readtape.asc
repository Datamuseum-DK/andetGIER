algol,_n<
_b_e_g_i_n
   _a_r_r_a_y buf[1:400];
   _i_n_t_e_g_e_r i,nchar,max;
   _r_e_a_l time;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   tapeoutput(2,buf);
   select(129);
   nchar := 0;
   max := 100;
   clock count;
   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l max _d_o
   _b_e_g_i_n
      writeinteger(|<ddddddddd|>,i);
      writechar(_i_f i=max _t_h_e_n 11 _e_l_s_e 27);
      nchar := nchar+11
   _e_n_d for i;
   select(17);
   end tape;
   time := clock count;
   writecr;
   writetext(|<<Writing: |>);
   write(|<ddddd.dd|>, time);
   writecr;
   writetext(|<<No. of characters: |>);
   writeinteger(|<p|>, nchar);
   writecr;
   writetext(|<<Char/sec: |>);
   write(|<ddddd.d|>,nchar/time)
_e_n_d;
