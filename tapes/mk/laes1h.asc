a25: gr  ra28              ; _p_r_o_c_e_d_u_r_e vk next track; _b_e_g_i_n saveR:=R;
     arn rb4   , sr  ra41  ; R:=length; R:=R-1;
     hs  c24            LT ; _i_f length<0 _t_h_e_n alarm(|<<full|>);
     qq  e2
     gr  rb4   , arn rb7   ; last track:=last track+1
     ar  ra41  , gr  rb7   ;
