	 writetext(|<<Fra pæl nr. |>);
	 writeinteger(|<p|>,areal[1]);
	 writetext(|<<:|>);
      _e_n_d;
      afstand2(areal[i],areal[j]);
      sum:=sum+x[areal[i]]*y[areal[j]]-y[areal[i]]*x[areal[j]]
   _e_n_d sum;
   sum:=abs(sum/2);
   LINE(1);
   writetext(|<<Areal: |>);
   write(|<ddddd.dd|>,sum);
   writetext(|<< kvadratmeter.|>);
   LINE(1);
   _g_o_t_o E;
G:
