e1:      qq
	 _e;
	 _i_f x = N _t_h_e_n
	    nsolutions:=nsolutions+1
	 _e_l_s_e
	 _b_e_g_i_n
	    empcol := empcol & (zero _s_h_i_f_t (-y));
	    empup := empup & (zero _s_h_i_f_t (x-y));
	    empdo := empdo & (zero _s_h_i_f_t (-x-y));
	    set(x+1);
	    empcol := empcol £ (one _s_h_i_f_t (-y));
