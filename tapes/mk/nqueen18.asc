   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   _p_r_o_c_e_d_u_r_e set(x);
   _v_a_l_u_e x;
   _i_n_t_e_g_e_r x;
   _b_e_g_i_n
      _i_n_t_e_g_e_r y;
      _b_o_o_l_e_a_n mask;
      y:=0;
      mask:=empcol & (empdo _s_h_i_f_t x) & (empup _s_h_i_f_t (-x));
      _f_o_r y := y _w_h_i_l_e 0|=_i_n_t_e_g_e_r mask _d_o
      _b_e_g_i_n
	 _c_o_d_e mask,y,zero;
	 3, 46;
	 3, 44;
	 2, 46;
	 arn pa1,nk re1
	 tk 1,mb a3
