algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r i,j,last tracks transferred;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   last tracks transferred:=tracks transferred;
   select(17);
   _f_o_r i:=500 _s_t_e_p 10 _u_n_t_i_l 620 _d_o
   _b_e_g_i_n
      _a_r_r_a_y A[1:i];
      clock count;
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l i _d_o
      _b_e_g_i_n
      A[i] := sin(j)+exp(-j)+arctan(1/j)+ln(j)+sqrt(j);
      _e_n_d _f_o_r;
      writecr;
      write(|<dddd|>, i);
      write(|<ddddd.dd|>, clock count);
      write integer(|<ddddddddd|>, tracks transferred-last tracks transferred);
      last tracks transferred := tracks transferred
   _e_n_d for i;
_e_n_d;
run<

