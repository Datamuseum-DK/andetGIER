algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e GPS1(I,N,Z,V);
   _i_n_t_e_g_e_r I,N,Z,V;
   _b_e_g_i_n
      writecr;
      writetext(|<<GPS1 start|>);
      _f_o_r I:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
      _b_e_g_i_n
         writecr;
	 write(|<-ddddd|>,I);
         Z := V
      _e_n_d;
      GPS1 := 1
   _e_n_d GPS1;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e GPS2(I,N,Z,V);
   _i_n_t_e_g_e_r I,N,Z,V;
   _b_e_g_i_n
      writecr;
      writetext(|<<GPS2 start|>);
      _f_o_r I:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
      _b_e_g_i_n
         writecr;
	 write(|<-ddddd|>,I);
         Z := V
      _e_n_d;
      GPS2 := 1
   _e_n_d GPS2;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e GPS3(I,N,Z,V);
   _i_n_t_e_g_e_r I,N,Z,V;
   _b_e_g_i_n
      writecr;
      writetext(|<<GPS3 start|>);
      _f_o_r I:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
      _b_e_g_i_n
         writecr;
	 write(|<-ddddd|>,I);
         Z := V
      _e_n_d;
      GPS3 := 1
   _e_n_d GPS3;
   _i_n_t_e_g_e_r I,P,A,Z,m;
   select(17);
   _f_o_r m:=2 _s_t_e_p 1 _u_n_t_i_l 10 _d_o
   _b_e_g_i_n
      writecr;
      I := 0;
      P := 0;
      Z := 0;
      I := GPS1(I, _i_f I=0 _t_h_e_n -1 _e_l_s_e I, P,
               _i_f I=1 _t_h_e_n 1 _e_l_s_e
	       _i_f GPS2(A,I,Z,_i_f A=1 _t_h_e_n 1 _e_l_s_e
	       _i_f entier(A)*(entier(I)_:entier(A))=entier(I) & A < I
	       _t_h_e_n 0 _e_l_s_e Z)=Z _t_h_e_n
	       (_i_f P<m _t_h_e_n P+1 _e_l_s_e I*GPS3(A,1,I,0)) _e_l_s_e P);
      write(|<-dddd|>, m, P)
   _e_n_d
_e_n_d
run<

