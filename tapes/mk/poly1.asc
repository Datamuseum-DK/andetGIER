	 _f_o_r j := k-1 _s_t_e_p -1 _u_n_t_i_l 0 _d_o
	 _b_e_g_i_n
	    R := beta*oldcora[j];
	    oldcora[j] := cora[j];
	    cora[j] := alfa*oldcora[j] + R + cora[j-1];
	    a[j] := a[j] + olda*cora[j]
	 _e_n_d for j;
	 beta := -SQSUM/OLDSQSUM;
	 OLDSQSUM := SQSUM;
	 alfa := -XPROD/SQSUM
      _e_n_d for k
   _e_n_d POLY-1;
   select(16);
