algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r i,numbers;
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e containsSeven(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      containsSeven := _f_a_l_s_e;
      _f_o_r n := n _w_h_i_l_e n>0 _d_o
      _b_e_g_i_n
         _i_f n _m_o_d 10=7 _t_h_e_n containsSeven := _t_r_u_e;
	 n := n _: 10
      _e_n_d
   _e_n_d containsSeven;
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e isMultipleOfSeven(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   isMultipleOfSeven := n _m_o_d 7=0;
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e sumContainsSeven(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   sumContainsSeven := containsSeven(sumOfDigits(n));
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e sumIsMultipleOfSeven(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   sumIsMultipleOfSeven := isMultipleOfSeven(sumOfDigits(n));
   _i_n_t_e_g_e_r  _p_r_o_c_e_d_u_r_e sumOfDigits(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r sum;
      sum := 0;
      _f_o_r n := n _w_h_i_l_e n>0 _d_o
      _b_e_g_i_n
         sum := sum+n _m_o_d 10;
	 n := n _: 10
      _e_n_d;
      sumOfDigits := sum
   _e_n_d containsSeven;
   select(17);
   writecr;
   numbers := 0;
   _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 100 _d_o
   _i_f -,(containsSeven(i) £ isMultipleOfSeven(i) £
         sumContainsSeven(i) £ sumIsMultipleOfSeven(i)) _t_h_e_n
   _b_e_g_i_n
      write(|<dddd|>, i);
      numbers := numbers+1;
      _i_f numbers _m_o_d 10=0 _t_h_e_n writecr
   _e_n_d
_e_n_d;
run<


   

