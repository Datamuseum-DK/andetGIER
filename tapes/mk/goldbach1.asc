algol,_n<
_b_e_g_i_n
   _c_o_m_m_e_n_t

   	GC70670

	N 55° 48.212 E 012° 25.751 

   Time: 409.40s = 6m 49.40s
   ;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e prime(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r test, max;
      max := sqrt(n)+1;
      prime := _f_a_l_s_e;
      _i_f n<2 _t_h_e_n _g_o_t_o not prime;
      _i_f n>3 _t_h_e_n
      _b_e_g_i_n
	 _f_o_r test:=2,3 _s_t_e_p 2 _u_n_t_i_l max _d_o
	 _i_f n _m_o_d test=0 _t_h_e_n _g_o_t_o not prime
      _e_n_d;
      prime := _t_r_u_e;
not prime:
   _e_n_d prime;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e next prime(n);
   _v_a_l_u_e n;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r next;
      next:=n;
      _f_o_r next := next+(_i_f next<3 _t_h_e_n 1 _e_l_s_e 2) _w_h_i_l_e -,prime(next) _d_o;
      next prime:=next
   _e_n_d next prime;
   _r_e_a_l _p_r_o_c_e_d_u_r_e acos(x);
   _v_a_l_u_e x;
   _r_e_a_l x;
   acos := 2*arctan(sqrt(1-x|&2)/(1+x));
   _r_e_a_l _p_r_o_c_e_d_u_r_e afstand(lćngdeA,breddeA,lćngdeB,breddeB);
   _v_a_l_u_e lćngdeA,breddeA,lćngdeB,breddeB;
   _r_e_a_l lćngdeA,breddeA,lćngdeB,breddeB;
   afstand:=acos(cos(breddeA)*cos(breddeB)*cos(lćngdeA-lćngdeB)+sin(breddeA)*sin(breddeB))*6378.245;
   _r_e_a_l _p_r_o_c_e_d_u_r_e d2r(deg);
   _v_a_l_u_e deg;
   _r_e_a_l deg;
   d2r:=deg/180*3.14159265;
   _r_e_a_l d,lćngdeA,breddeA,lćngdeB,breddeB;
   _a_r_r_a_y llist,blist[1:2000];
   _i_n_t_e_g_e_r i,j,n,b0,b1,b2,b3,l0,l1,l2,l3;
   _p_r_o_c_e_d_u_r_e WRITE(x);
   _v_a_l_u_e x;
   _r_e_a_l x;
   _b_e_g_i_n
      _i_n_t_e_g_e_r a,b;
      a:=entier(x);
      b:=(x-a)*60000;
      write(|< dd|>,a);
      write integer(|<dd.ddd|>,b)
   _e_n_d;
   select(32);
   clock count;
   breddeA:=d2r(55+48.212/60);
   lćngdeA:=d2r(12+25.751/60);
   n:=200;
   b0:=5548212;
   l0:=1225751;
   b1:=b0-n/2*15.68;
   l1:=l0-n/2*14.14;
   _i_f b1 _m_o_d 2=0 _t_h_e_n b1:=b1-1;
   _i_f l1 _m_o_d 2=0 _t_h_e_n l1:=l1-1;
   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
   _b_e_g_i_n
      b1:=next prime(b1);
      l1:=next prime(l1);
      b2:=b1 _: 100000;
      b3:=b1 _m_o_d 100000;
      blist[i]:=b2+b3/60000;
      l2:=l1 _: 100000;
      l3:=l1 _m_o_d 100000;
      llist[i]:=l2+l3/60000;
      writecr;
      write(|<-dddddddd|>,i,b1,l1,b1-b0,l1-l0)
   _e_n_d;
   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
   _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
   _b_e_g_i_n
      breddeB:=d2r(blist[i]);
      lćngdeB:=d2r(llist[j]);
      d:=afstand(lćngdeA,breddeA,lćngdeB,breddeB);
      _i_f d<1.60934*2.0 _t_h_e_n
      _b_e_g_i_n
	 writecr;
	 WRITE(blist[i]);
	 WRITE(llist[j]);
	 write(|< dd.ddd|>,d)
      _e_n_d
   _e_n_d for j and i;
   writecr;
   writetext(|<<Time: |>);
   write(|<ddddddd.dd|>,clock count);
   writecr
_e_n_d;
run<
