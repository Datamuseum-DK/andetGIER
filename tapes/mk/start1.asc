	 writetext(|<<s|>)
      _e_n_d print
   _e_n_d clock;
   clock(_f_a_l_s_e);
   _f_o_r run:=0 _s_t_e_p 1 _u_n_t_i_l 30 _d_o runs[run]:=0;
   year:=0;
