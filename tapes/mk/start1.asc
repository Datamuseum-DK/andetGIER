	 number:=number_:10
      _e_n_d _f_o_r;
      old has 1:=_f_a_l_s_e;
bad:
   _e_n_d old has 1;
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e has 1(number);
   _v_a_l_u_e number;
   _i_n_t_e_g_e_r number;
   _c_o_d_e has 1, number;
   2, 42;
   3, 44;
     srn c42   , gr p-1    ; has 1:=_t_r_u_e;
     arn pa2               ; e1: R:=number;
e1:  hv  re2           LZ  ; _i_f R=0 _t_h_e_n _g_o_t_o e2;
     xr                    ; M:=number;
     dln re3   X	   ; M:=number _: 10; R:=number _m_o_d 10;
     sr  c42               ; R:=R-1;
     hv  re9           LZ  ; _i_f R=0 _t_h_e_n _g_o_t_o e9;
     hv  re1   X           ; R:=number;_g_o_t_o e1;
e2:  grn p-1   V           ; e2: has 1:=_f_a_l_s_e;
e3:  qq  10.39             ; 10
e9:                        ; e9:
   _e;
   _p_r_o_c_e_d_u_r_e clock(print);
   _v_a_l_u_e print;
   _b_o_o_l_e_a_n print;
   _b_e_g_i_n
      _r_e_a_l c,d,h,m,s;
      _i_n_t_e_g_e_r id,ih,im;
      _c_o_m_m_e_n_t
         1d 2h 3m 45.67s = 45.67 + 3*60 + 2*60*60 + 1*60*60*24 = 93825.67s;
      _c_o_d_e c;
      3, 45;
      zl, grf pa1;
      _e;
      _i_f print _t_h_e_n
      _b_e_g_i_n
         write(|<dddddddddd.dd|>,c);
	 writetext(|<<s = |>);
         h:=c/3600;
	 id:=entier(h/24);
	 h:=h-id*24;
	 ih:=entier(h);
	 h:=h-ih;
	 h:=h*60;
	 im:=entier(h);
	 h:=h-im;
	 s:=h*60;
	 _i_f id>0 _t_h_e_n
	 _b_e_g_i_n
	    writeinteger(|<p|>,id);
	    writetext(|<<d |>)
	 _e_n_d;
	 _i_f ih>0 _t_h_e_n
