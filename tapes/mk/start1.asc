   leap year := ((year _m_o_d 4=0) & (year _m_o_d 100 |= 0)) Ł (year _m_o_d 400=0);
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e days in month(year, month);
   _v_a_l_u_e year, month;
   _i_n_t_e_g_e_r year, month;
   days in month := _c_a_s_e month _o_f (31,_i_f leap year(year) _t_h_e_n 29
   _e_l_s_e 28,31,30,31,30,31,31,30,31,30,31);
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e old has 1(number);
