algol,_n<
_b_e_g_i_n
   _i_n_t_e_g_e_r year,month,day,days,run,max run;
   _b_o_o_l_e_a_n dmy;
   _i_n_t_e_g_e_r _a_r_r_a_y runs[0:30];
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e leap year(year);
