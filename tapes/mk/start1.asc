      writeinteger(|<p|>,day);
      writechar(59);
      writeinteger(|<p|>,month);
      writechar(59);
      writeinteger(|<p|>,year);
      writechar(0);
      writeinteger(|<p|>,_i_n_t_e_g_e_r (dmy Ł ((_b_o_o_l_e_a_n run)_s_h_i_f_t 30)))
   _e_n_d print;
   _i_f run>max run _t_h_e_n max run:=run;
   runs[run]:=runs[run]+1;
   day:=day+1;
