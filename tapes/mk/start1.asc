   day:=1;
   max run:=0;
   days:=days in month(year+2000,month);
again:
   dmy:=((_b_o_o_l_e_a_n day) _s_h_i_f_t 20) Ł
        ((_b_o_o_l_e_a_n month) _s_h_i_f_t 10) Ł
