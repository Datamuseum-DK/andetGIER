     ca (s 8e5), hv a6     ; _i_f digit=board[s+8] _t_h_e_n _g_o_t_o NOT OK;
     ud  pe2               ; s:=address of start of column;
     ca (s  e5), hv a6     ; _i_f digit=board[s   ] _t_h_e_n _g_o_t_o NOT OK;
     ca (s 9e5), hv a6     ; _i_f digit=board[s+ 9] _t_h_e_n _g_o_t_o NOT OK;
