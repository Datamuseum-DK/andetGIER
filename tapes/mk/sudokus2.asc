     ca (s  e5), hv a6     ; _i_f digit=board[s   ] _t_h_e_n _g_o_t_o NOT OK;
     ca (s 1e5), hv a6     ; _i_f digit=board[s+ 1] _t_h_e_n _g_o_t_o NOT OK;
     ca (s 2e5), hv a6     ; _i_f digit=board[s+ 2] _t_h_e_n _g_o_t_o NOT OK;
