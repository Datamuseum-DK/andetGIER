algol<
_b_e_g_i_n
   _r_e_a_l _p_r_o_c_e_d_u_r_e DET(A,n);
   _v_a_l_u_e n;
   _a_r_r_a_y A;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,p,j;
      _r_e_a_l z,temp,b;
      z:=1;
L:    p:=1;
      _f_o_r i:=2 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _i_f abs(A[i,1])>abs(A[p,1]) _t_h_e_n p:=i;
      _i_f n>1 & p|=1 _t_h_e_n
      _b_e_g_i_n
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 _b_e_g_i_n
	    temp:=A[1,j];
	    A[1,j]:=A[p,j];
	    A[p,j]:=temp
	 _e_n_d;
	 z:=-z;
	 writecr; write(|<-ddddd|>,n,z);
      _e_n_d;
      b:=A[1,1];
      z:=z*b;
      _i_f z|=0 & n>1 _t_h_e_n
      _b_e_g_i_n
         _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 A[i,j]:=A[i,j]-A[i,1]/b*A[1,j];
	 n:=n-1;
         _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 A[i,j]:=A[i+1,j+1];
	 _g_o_t_o L
      _e_n_d
      _e_l_s_e
      DET:=z
   _e_n_d DET;
   _i_n_t_e_g_e_r n;
   select(16);
L: n:=read integer;
   _i_f n>1 _t_h_e_n
   _b_e_g_i_n
      _a_r_r_a_y A[1:n,1:n];
      _i_n_t_e_g_e_r i,j;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      A[i,j]:=read real;
      writecr;
      write(|<-d.dddddd'-dd|>,DET(A,n));
      _g_o_t_o L
   _e_n_d
_e_n_d;
run<
3
-2, 2, -3
-1, 1, 3
2, 0, -1
4
2,5,3,5
4,6,6,3
11,3,2,-2
4,-7,9,3
