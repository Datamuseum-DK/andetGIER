algol,_n<
_b_e_g_i_n
   _c_o_m_m_e_n_t

   	GC87982

   Time: 409.40s = 6m 49.40s
   ;
   _i_n_t_e_g_e_r alen,alen1,alen1000,cipher len,rotorno;
   _i_n_t_e_g_e_r initial shift,shift;
   _i_n_t_e_g_e_r i,c1,c2,c3,c4,c5,c6;
   _b_o_o_l_e_a_n found;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   _r_e_a_l _p_r_o_c_e_d_u_r_e acos(x);
   _v_a_l_u_e x;
   _r_e_a_l x;
   acos := 2*arctan(sqrt(1-x|&2)/(1+x));
   _r_e_a_l _p_r_o_c_e_d_u_r_e afstand(lćngdeA,breddeA,lćngdeB,breddeB);
   _v_a_l_u_e lćngdeA,breddeA,lćngdeB,breddeB;
   _r_e_a_l lćngdeA,breddeA,lćngdeB,breddeB;
   afstand:=acos(cos(breddeA)*cos(breddeB)*cos(lćngdeA-lćngdeB)+sin(breddeA)*sin(breddeB))*6378.245;
   _r_e_a_l _p_r_o_c_e_d_u_r_e d2r(deg);
   _v_a_l_u_e deg;
   _r_e_a_l deg;
   d2r:=deg/180*3.14159265;
   _r_e_a_l d,lćngdeA,breddeA,lćngdeB,breddeB;
   select(32);
   clock count;
   alen:=read integer;
   alen1:=alen-1;
   alen1000:=alen*1000;
   cipher len:=read integer;
   _b_e_g_i_n
      _i_n_t_e_g_e_r _a_r_r_a_y alphabet,rotor,delta1,delta2,reflector[0:alen1];
      _i_n_t_e_g_e_r _a_r_r_a_y reverse alphabet[0:63];
      _i_n_t_e_g_e_r _a_r_r_a_y cipher,clear[1:cipher len];
      _p_r_o_c_e_d_u_r_e read alphabet;
      _b_e_g_i_n
         _i_n_t_e_g_e_r i,c;
         i:=0;
again:
         c:=lyn;
	 _i_f c=60 Ł c=58 _t_h_e_n _g_o_t_o again;
	 _i_f c=64 _t_h_e_n _g_o_t_o exit;
	 alphabet[i]:=c;
	 reverse alphabet[c]:=i;
	 i:=i+1;
	 _g_o_t_o again;
exit:
      _e_n_d read alphabet;
      _p_r_o_c_e_d_u_r_e generate rotor(p);
      _v_a_l_u_e p;
      _i_n_t_e_g_e_r p;
      _b_e_g_i_n
         _i_n_t_e_g_e_r i,j,c,c2;
	 _c_o_m_m_e_n_t PERM code taken from APL/360 ADVANCEDEX PERM function;
	 _p_r_o_c_e_d_u_r_e PERM(Z,a,b);
	 _v_a_l_u_e a,b;
	 _i_n_t_e_g_e_r a,b;
	 _i_n_t_e_g_e_r _a_r_r_a_y Z;
	 _b_e_g_i_n
	    _i_n_t_e_g_e_r i,j,rem;
	    rem:=b-1;
	    _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l a _d_o
	    _b_e_g_i_n
	       Z[a-i+1]:=1+rem _m_o_d i;
	       rem:=rem_:i
	    _e_n_d;
	    _f_o_r i:=a-1 _s_t_e_p -1 _u_n_t_i_l 1 _d_o
	    _f_o_r j:=i+1 _s_t_e_p 1 _u_n_t_i_l a _d_o
	    _i_f Z[i]_<Z[j] _t_h_e_n Z[j]:=Z[j]+1
	 _e_n_d PERM;
	 _i_n_t_e_g_e_r _a_r_r_a_y perm[1:alen];
	 PERM(perm,6,p);
	 _f_o_r j:=0 _s_t_e_p 1 _u_n_t_i_l alen1 _d_o
	 _b_e_g_i_n
	    i:=rotor[j]:=reverse alphabet[perm[j+1]];
	    delta1[j]:=(i-j+alen)_m_o_d alen;
	    delta2[i]:=(j-i+alen)_m_o_d alen
	 _e_n_d delta
      _e_n_d generate rotor;
      _p_r_o_c_e_d_u_r_e read reflector;
      _b_e_g_i_n
         _i_n_t_e_g_e_r i,c,c2;
	 i:=0;
again:
         c:=lyn;
	 _i_f c=60 Ł c=58 _t_h_e_n _g_o_t_o again;
	 _i_f c=64 _t_h_e_n _g_o_t_o exit;
	 c2:=reverse alphabet[c];
	 reflector[i]:=c2;
	 i:=i+1;
	 _g_o_t_o again;
exit:
      _e_n_d read reflector;
      _p_r_o_c_e_d_u_r_e read cipher;
      _b_e_g_i_n
         _i_n_t_e_g_e_r i,c,c2;
	 i:=0;
again:
         c:=lyn;
	 _i_f c=60 Ł c=58 _t_h_e_n _g_o_t_o again;
	 _i_f c=64 _t_h_e_n _g_o_t_o exit;
	 c2:=reverse alphabet[c];
	 i:=i+1;
	 cipher[i]:=c2;
	 _g_o_t_o again;
exit:
      _e_n_d read cipher;
      read alphabet;
      read reflector;
      read cipher;
      breddeA:=d2r(55+47.222/60);
      lćngdeA:=d2r(12+24.600/60);
      _f_o_r rotorno:=1 _s_t_e_p 1 _u_n_t_i_l 720 _d_o
      _b_e_g_i_n
         shift:=0;
	 generate rotor(rotorno);
	 found:=_f_a_l_s_e;
	 _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l cipher len _d_o
	 _b_e_g_i_n
	    c2:=cipher[i];
	    shift:=shift+1;
	    c3:=(c2+delta1[(c2-shift+alen1000)_m_o_d alen])_m_o_d alen;
	    c4:=reflector[c3];
	    c5:=(c4+delta2[(c4-shift+alen1000)_m_o_d alen])_m_o_d alen;
	    clear[i]:=c5;
	 _e_n_d cipher len;
	 breddeB:=d2r((clear[1]+1)*10+
	              (clear[2]+1)+
		     ((clear[3]+1)*10+
		      (clear[4]+1)+
		      (clear[5]+1)*0.1+
		      (clear[6]+1)*0.01+
		      (clear[7]+1)*0.001)/60);
	 lćngdeB:=d2r((clear[8]+1)*10+
	              (clear[9]+1)+
		     ((clear[10]+1)*10+
		      (clear[11]+1)+
		      (clear[12]+1)*0.1+
		      (clear[13]+1)*0.01+
		      (clear[14]+1)*0.001)/60);
         d:=afstand(lćngdeA,breddeA,lćngdeB,breddeB);
	 _i_f d<1.60934*2.0 _t_h_e_n
	 _b_e_g_i_n
	    writecr;
	    writechar(58);
	    write(|<ddd|>,rotorno);
	    write(|<ddddd.dd|>,d);
	    writetext(|<<  |>);
	    _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l cipher len _d_o
	    writechar(alphabet[clear[i]]);
	    writechar(58)
	 _e_n_d found
      _e_n_d for rotorno
   _e_n_d inner loop;
   writecr;
   writetext(|<<Time: |>);
   write(|<ddddddd.dd|>,clock count);
   writecr
_e_n_d;
run<
6
14
123456
341265
63355312646222
55xxyyy12xxyyy
#011
