algol<
Clean unused disk tracks
_b_e_g_i_n
   _b_e_g_i_n
      _i_n_t_e_g_e_r FREE, track, ntrack, index, GA4;
      _i_n_t_e_g_e_r _a_r_r_a_y A[0:39];
      _b_o_o_l_e_a_n code1;
      _c_o_r_e _c_o_d_e code1,A,index;
      3, 46;
      3, 48;
      3, 44;
      arn pa3                  ; R:=index;
      qq      V        NKB     ; _i_f kbon _t_h_e_n
      gr  c17 V        M       ; UV:=R _e_l_s_e
      grn c17          M       ; UV:=0 incl marks;
      arn pa2, ar pa3
      us  0  , hr  s1
      _e;


      where(|<<free|>, FREE);

      ntrack := _i_n_t_e_g_e_r(((_b_o_o_l_e_a_n FREE)_s_h_i_f_t -16)&_2_4 0 _1_6 m);

      select(17);
      writecr;
      writeinteger(|<p|>,ntrack);

      _f_o_r index:=0 _s_t_e_p 1 _u_n_t_i_l 39 _d_o gier(code1);
      _f_o_r track:=1 _s_t_e_p 1 _u_n_t_i_l ntrack _d_o
      put(A, FREE, track);

      where(|<<ga4|>,GA4);

      ntrack := _i_n_t_e_g_e_r(((_b_o_o_l_e_a_n GA4)_s_h_i_f_t -16)&_2_4 0 _1_6 m);
      index := _i_n_t_e_g_e_r((_b_o_o_l_e_a_n GA4)&_2_4 0 _1_6 m);
      writecr;
      writeinteger(|<p|>,ntrack);
      writecr;
      writeinteger(|<p|>,index);
      _f_o_r track:=index+ntrack _s_t_e_p 1 _u_n_t_i_l 449, 500 _s_t_e_p 1 _u_n_t_i_l 959 _d_o
      _b_e_g_i_n
         writecr;
	 writeinteger(|<p|>,track);
         put(A, _i_n_t_e_g_e_r (_5 0 _1 1 _1_8 960 _1_6 0), track+1)
      _e_n_d
   _e_n_d clean free;
_e_n_d;
t<

