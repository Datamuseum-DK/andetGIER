_b k=e90,  i=0            ;
_d i =e89                 ;
qq 194.9+15e0.19+92.39 f ; pass 6 word for arctan
_t arctan;                ; identifier
_d e71=1e71,  e89=i       ; count identifiers
_e                        ;
