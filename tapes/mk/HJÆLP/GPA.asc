     vk  (6e4)    ,  is  (e2)  ;
     lk  s-40     ,  arn (e2)  ;
     qq   (e2)    t  -82   LB  ;
     qq   (1e4)   t  -1        ;
[INADDRESS]                    ;
 e2: arn   81e13  t  1         ; unpack next word
     ga    e13-4  V        NA  ;
     hv    a12                 ;
     tk    10     ,  ga  e13-3 ;
     tk    10     ,  ga  e13-2 ;
     tk    10     ,  ga  e13-1 ;
[BYTEADDRESS]                  ;
 e1: arn   e13-1  t  -4        ;
     hr    s1                  ;
