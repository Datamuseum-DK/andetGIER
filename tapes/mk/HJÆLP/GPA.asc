     arn (e12)    ,  qq  e30   ;
     qq   (e12)   t  -82   LB  ;
a11: qq   (1e4)   t  1         ; used:=used+1
e11: hv    e12                 ;
[DRUMIN]                       ;
a12: arn (6e4)    D  1         ;
