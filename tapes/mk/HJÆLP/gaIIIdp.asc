      gr   c37   X               ; UV:=q1; R:=remainder
      dk   c54   X               ; M:=q2*2|&(-39)
      arn  c37     ,nl   ra1     ; normalize the quotient
      tl  -10      ,gr   c37     ; UV:=head of the mantissa(a/b)
      arn  c47                   ;
a:    sr   _0    D                ;
a1:   ar   _0    D NO   t1        ; Raddr:=expa-expb+norm.exp.+1
      ga   c37   V NO            ; _i_f exp_>-512&exp<511 _t_h_e_n UVaddr:=exp
      hv   0       NT            ; _e_l_s_e _i_f exp>511 _t_h_e_n alarm(|<<spill|>)
      grn  c37   X LO            ; _i_f a=0Łexp<-512 _t_h_e_n UV:=M:=0
a2:   gm   1c37    ,hv   c51     ; exit: UV1:=M; _g_o_t_o RS

