    is (c46) , hv  s1   ;  _i_f n |= 0 _t_h_e_n _g_o _t_o location[last used + 1];
    pm  p4   , hs  c22  ;  take formal (store[p+4]);
    arn p -2            ;
    nkf 39   , grf(c36) ;  store[UA]:= float(length);
    arn p1   , ck  -10  ;
    ar  p-1  D          ;  pack (R, 0,9,address(length)-1, 10,19,i, 20,39,0);
    hs  c11  , qq e26.29;  to drum (R);
    ps  p5   , hh  c6   ;  s:= p+6;  _g_o _t_o exit proc;

a17:arn c41  V  NKB     ; kb on: R:= _i_f NKB _t_h_e_n _f_a_l_s_e _e_l_s_e _t_r_u_e;
    arn c40             ;
    hv  c14             ;  _g_o _t_o end R expr;
