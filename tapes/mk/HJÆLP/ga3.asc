    pm  p-3  XV   IRC   ;  R:= store[p-3]; RC:= marks(store[p-3]); skip;
a16:hs  ra11 ,          ; rep:  one word;
    gr (p1)     MRC     ;  store[i]:= R and RC marks;
    pmn(p1)  DX 1       ;  i:= i+1;
