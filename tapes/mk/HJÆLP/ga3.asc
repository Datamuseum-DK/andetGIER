      pm   s1   X                ;
      pm   s2      ,gr   s2      ; M:=description(b); formal[2]:=a1
      grn  1c37    ,hs   c22     ; UV1:=0; _g_o_t_o take formal
      ps  (c46)    ,pp  (c36)    ; s:=addr(a)-1; p:=addr(b)
      pp   p-1                   ; p:=p-1
      arnf p1  X  IZB            ;
      ga   c47     ,gm   c54     ; c47[0-9]:=expb; loc[c54]:=b
      arnf s1  X  IZA            ;
      sr  (c47)D  ITB            ; Raddr:=expa-expb
      ga   c47    LZB            ; _i_f b=0 _t_h_e_n c47[0-9]:=expa
      mt  -1   D  NTB            ; _i_f expa<expb _t_h_e_n Raddr:=Raddr*(-1)
      ar   68  D  ITA            ; Raddr:=Raddr+68; TA:=abs(expa-expb)>68
      ga   rb      ,arn  s1      ; b[0-9]:= -abs(expa-expb)+68
      ps   p   XV LTB            ; _i_f expa_>expb _t_h_e_n _b_e_g_i_n x:=a; y:=b; x1:=a1
      ga   c47  V NZC            ; y1:=b1; _i_f a|=0&b|=0 _t_h_e_n c47[0-9]:= expa
                                 ; _e_n_d _e_l_s_e _b_e_g_i_n
      pp  (c46) V LTB            ; x:=b;y:=a; x1:=b1; y1:=a1 _e_n_d
      arn  c54     ,gm   c54     ; loc[c54]:=x
      pm   p2      ,pp  (c47)    ; M:=y1; R:=y; p:=resulting exponent (nearly)
      qq        V NTA            ;
      tln -39   V NZC            ; _i_f TA&a|=0&b|=0 _t_h_e_n R:=M:=y:=y1:=0 _e_l_s_e
b:    tl   _0      NZC  t-68      ; shift to same exponent
      gr   c68 X                 ;
      ar   s2      ,tl  -39      ; M:=y1+x1
      ar   c54     ,ar   c68     ; R:=mente+x+y
      nl   rb1     ,tl  -10      ; normalize float.
      gr   c37     ,ps  (c46)    ; UV:=head of the result; s:=last used
      qq  (c46)        t1        ; last used:=last used+1
b1:   arn  p_0   D NZ   t10       ; _i_f result|=0 _t_h_e_n calculate exponent
      ga   c37  V NO             ; _i_f exp_>-512&exp<512 _t_h_e_n set exponent in UVaddr
