b12:                      ;
c6: pm  _d_2         ITA    ; clear R: R was used:= kind[R used in] = VinR;
    [R used in]           ;
a7: pmn b5    XV   NC     ;    _i_f class[R used in] = R _t_h_e_n
    hr  s1                ;    _b_e_g_i_n
    hs  a6                ;       call (get next work);
    hs  e3                ;       output (w rel); operand[R used in] :=
    gm (b12)  MB          ;       VinW, w rel, 0, no clear;
    pm  d12   DV   LTA    ;       _i_f R was used _t_h_e_n output (clear R)
    pm  d13   D           ;       _e_l_s_e output (clear RF);
    pa  b12   t  d2       ;       set R not used;
    hv  e3    X           ;    _e_n_d; return;

[The work table consists of a single machine word. Bit 0 is always 1. Bit
n is 1 if working location n is occupied, 0 otherwise. The machine in-
struction nk with work table in the R-register will shift R until first
free working location is in bit 1.]

c7: pmn b5    X           ; get next work:
a6: nk  b13   , ar  5a    ;    scan work table for first free working loc;
b13:tk  _0     , gr  b5    ;    reserve work;
    [wrel]                ;
b14h:pm(b13)  DX _0        ;    Radr:= w rel:= w + wbase 2;
    [wbase 2]             ;
    it (b13)  , pt  a     ;    form descr. of working loc;
    it (b13)  , bs (b6)   ;    _i_f minimum w > w rel _t_h_e_n
b6: qq  _0     t -1        ;    minimum w := minimum w - 1;
    [minimum w]           ;
    pm  a     , hr  s1    ;    M:= descr of working loc; return;
