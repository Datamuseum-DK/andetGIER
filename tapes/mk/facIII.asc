algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r n;
   _r_e_a_l log10, logfac;

   log10 := 1/ln(10);
   logfac := 0;

   select(16);
   _f_o_r n:=1 _s_t_e_p 1 _u_n_t_i_l 1000 _d_o
   _b_e_g_i_n
      logfac := logfac+ln(n);
      _i_f n_<100 £
         (n_<800 & n _m_o_d 25=0) £
	 (n _m_o_d 50=0) _t_h_e_n
      _b_e_g_i_n
         writecr;
         write(|<dddd|>, n);
         write(|<  dddd.dddd|>, logfac*log10)
      _e_n_d
   _e_n_d
_e_n_d;
t<

