slip<
i=10
_b a10,e10
     zq                    ; [10] c:=-1;
a1:  pp  42    , hs  re3   ; [11] p:=42; separator;
a2:  pmn -1    t   1       ; [12] c:=c+1; M:=celle[c]; R:=0;
     ar  1.1   D       LA  ; [13] _i_f mark A _t_h_e_n R _p_o_s 1:=1;
     ar  1.2   D       LB  ; [14] _i_f mark B _t_h_e_n R _p_o_s 2:=1;
     xr        , cl  0     ; [15] swap R and M; indicate sign of R
a3:  pa  re1   Vt500   LO  ; [16] _f_o_r p:=42 _s_t_e_p -1 _u_n_t_i_l 1 _d_o _b_e_g_i_n
                           ;      _i_f R<0 _t_h_e_n constant:=500
