     hs  re0               ; [18] play
     cl  1     , pp  p-1   ; [19] RM:=RM _s_h_i_f_t 1; _c_o_m_m_e_n_t M0 not shifted;
     bs p      , hv  ra3   ; [20] _e_n_d for p;
