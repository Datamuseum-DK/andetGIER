_b_e_g_i_n
   _i_n_t_e_g_e_r top,i;
   _i_n_t_e_g_e_r _a_r_r_a_y A[1:1];
   _i_n_t_e_g_e_r _a_r_r_a_y B[1:40];

   top := tromle plads;

   A[1] := 117;

   til tromle(A);

   skrvvr;
   skrv(|<dddddd|>, top);
   skrvvr;
   skrv(|<dddddd|>, tromle plads);

   tromle plads := top;
   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 40 _d_o B[i] := i;

   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 320 _d_o
   _b_e_g_i_n
      skrvvr;
      skrv(|<dddddd|>, tromle plads);
      til tromle(B)
   _e_n_d
_e_n_d;

