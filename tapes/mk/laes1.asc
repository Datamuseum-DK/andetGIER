     hv  ra8               ; 54
     hv  ra8               ; 55
     hv  ra8               ; 56
     hv  ra8               ; 57
     hv  ra1               ; 58
     hv  ra1               ; 59
     hv  ra1               ; 60
     hv  ra12              ; 61: SUM CODE
     hv  ra1               ; 62
     hv  ra1               ; 63
     hv  ra8               ; 64
d2=i-1
