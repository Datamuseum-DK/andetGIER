   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 3 _d_o
   _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l 3 _d_o
   _f_o_r k:=1 _s_t_e_p 1 _u_n_t_i_l 3 _d_o
   _f_o_r l:=1 _s_t_e_p 1 _u_n_t_i_l 3 _d_o
   submatrices[(i-1)*27+(j-1)*3+(k-1)*9+l] := (i-1)*27+(j-1)*3+1;

   clock count;

   print;
   s:=0;
   p:=1;
a1:
   _i_f board[p]=0 _t_h_e_n _g_o_t_o a2;
   p:=p+1;
   _i_f p=82 _t_h_e_n _g_o_t_o FOUND;
   _g_o_t_o a1;
a2:
   stack[s]:=p;
   stack[s+1]:=0;
a3:
   p:=stack[s];
   digit:=stack[s+1];
   stack[s+1]:=digit:=digit+1;
   _i_f digit=10 _t_h_e_n
   _b_e_g_i_n
      s:=s-2;
      _i_f s<0 _t_h_e_n _g_o_t_o BAD;
      board[stack[s]]:=0;
      _g_o_t_o a3
   _e_n_d;
a4:
   row1:=rows[p];
   col1:=cols[p];
   _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
   _b_e_g_i_n
      _i_f board[row1+i]=digit _t_h_e_n _g_o_ _t_o NOTOK
   _e_n_d _f_o_r;
   _f_o_r i:=0 _s_t_e_p 9 _u_n_t_i_l 72 _d_o
   _b_e_g_i_n
      _i_f board[col1+i]=digit _t_h_e_n _g_o_ _t_o NOTOK
   _e_n_d _f_o_r;
   mat1 := submatrices[p];
   _f_o_r i:=0 _s_t_e_p 9 _u_n_t_i_l 18 _d_o
   _f_o_r j:=0 _s_t_e_p 1 _u_n_t_i_l 2 _d_o
   _b_e_g_i_n
      _i_f board[mat1+i+j]=digit _t_h_e_n _g_o_ _t_o NOTOK
   _e_n_d _f_o_r;
   _c_o_m_m_e_n_t use digit in cell p;
   board[p]:=digit;
   stack[s+1]:=digit;
   s:=s+2;
   _g_o_t_o a1;
NOTOK:
   _g_o_t_o a3;

FOUND:
   writecr;
   writetext(|<<Finished clock: |>);
   write(|<-ddddddddd.d|>, clock count);
   print;
   _g_o_t_o skip;
BAD:
