loop:
   clock count;
   select(16);
   N:=read integer;
   M:=read integer;
   _b_e_g_i_n
      _i_n_t_e_g_e_r _a_r_r_a_y matrix[1:M,1:N],antal[1:M],brugt,resultat[1:N];
      _p_r_o_c_e_d_u_r_e prřv(niveau);
      _v_a_l_u_e niveau;
      _i_n_t_e_g_e_r niveau;
      _b_e_g_i_n
	 _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e passer(sřjle,bogstav);
	 _v_a_l_u_e sřjle,bogstav;
	 _i_n_t_e_g_e_r sřjle,bogstav;
	 _b_e_g_i_n
	    passer:=_t_r_u_e;
	    _i_f brugt[sřjle]=0 _t_h_e_n
	    _b_e_g_i_n
	       brugt[sřjle]:=1;
	       resultat[sřjle]:=bogstav
	    _e_n_d
	    _e_l_s_e _i_f resultat[sřjle]=bogstav _t_h_e_n
	    brugt[sřjle]:=brugt[sřjle]+1
	    _e_l_s_e passer:=_f_a_l_s_e
	 _e_n_d passer;

	 _p_r_o_c_e_d_u_r_e afprřv;
	 _b_e_g_i_n
	    _i_f niveau<M _t_h_e_n
	    _b_e_g_i_n
	       prřv(niveau+1)
	    _e_n_d
	    _e_l_s_e
	    _b_e_g_i_n
	       _i_n_t_e_g_e_r i,j,ok;
	       _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l M _d_o
	       _b_e_g_i_n
		  ok:=0;
		  _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
		  _i_f resultat[j]=matrix[i,j] _t_h_e_n ok:=ok+1;
		  _i_f ok |= antal[i] _t_h_e_n _g_o_t_o passer ikke
	       _e_n_d _f_o_r;
	       writecr;
	       writechar(58);
	       _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
	       _b_e_g_i_n
		  writechar(14);
		  writechar(60);
		  writechar(resultat[i]);
		  writechar(58)
	       _e_n_d i;
	       writeinteger(|<d|>,N);
	       _g_o_t_o slut
	    _e_n_d;
 passer ikke:
	 _e_n_d afprřv;
	 _b_e_g_i_n
	    _i_n_t_e_g_e_r _a_r_r_a_y stak[1:antal[niveau]];
	    _i_n_t_e_g_e_r spnt,sspnt,antal niveau,i;
	    antal niveau:=antal[niveau];
	    spnt:=1;
	    sspnt:=stak[1]:=0;
	    _g_o_t_o igen2;
igen:
	    brugt[sspnt]:=brugt[sspnt]-1;
igen2:
            _i_f sspnt=N _t_h_e_n
	    _b_e_g_i_n
	       spnt:=spnt-1;
	       _i_f spnt=0 _t_h_e_n _g_o_t_o afslut;
	       sspnt:=stak[spnt];
	       _g_o_t_o igen
	    _e_n_d;
	    sspnt:=stak[spnt]:=sspnt+1;
	    _i_f -,passer(sspnt,matrix[niveau,sspnt]) _t_h_e_n _g_o_t_o igen2;
	    _i_f spnt<antal niveau _t_h_e_n
	    _b_e_g_i_n
	       spnt:=spnt+1;
	       sspnt:=stak[spnt]:=stak[spnt-1];
	       _g_o_t_o igen2
	    _e_n_d;
	    afprřv;
	    _g_o_t_o igen;
afslut:
	 _e_n_d inner block
      _e_n_d prřv;

      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l M _d_o
      _b_e_g_i_n
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
	 _b_e_g_i_n
again:
            c:=lyn;
	    _i_f c=58 Ł c=60 _t_h_e_n _g_o_t_o again;
	    matrix[i,j]:=c
	 _e_n_d for j;
	 antal[i]:=read integer
      _e_n_d for i;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o brugt[i]:=resultat[i]:=0;
      prřv(1);
slut:
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l M _d_o
      _b_e_g_i_n
         writecr;
	 writechar(60);
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l N _d_o
	 _b_e_g_i_n
	    _i_f matrix[i,j]=resultat[j] _t_h_e_n
	    _b_e_g_i_n
	       writechar(58);
	       writechar(14);
	       writechar(60)
	    _e_n_d;
	    writechar(matrix[i,j])
	 _e_n_d j;
	 writechar(58);
	 writeinteger(|<d|>,antal[i])
      _e_n_d j
   _e_n_d inner block;
   writecr;
   writetext(|<<Tid: |>);
   write(|<ddddddd.dd|>,clock count);
   _i_f char|=11 _t_h_e_n _g_o_t_o loop
_e_n_d;
