algol<
_b_e_g_i_n
   _r_e_a_l _p_r_o_c_e_d_u_r_e Det Gauss(n,m,A,exit);
   _v_a_l_u_e n, m;
   _i_n_t_e_g_e_r n, m;
   _a_r_r_a_y A;
   _l_a_b_e_l exit;
   _c_o_m_m_e_n_t Det Gauss solves m systems of linear equations with n un-
	   knowns and computes the determinant of the coefficient matrix.

	   The parameters are:

	   n:    Number of unknowns.
	   m:    Number of right hand sides. m=0 implies that only the
		 determinant wil be computed (cf. section 2).
	   A:    Has the bounds [1:n,1:n+m] and must on entry con-
		 tain the coefficient matrix in A[1:n,1:n] and the right
		 hand sides in A[1:n,n+1:n+m]. The solution vectors
		 are on exit stored as columns in A[1:n,n+1:n+m].
	   exit: Label to which Det Gauss goes when the system is sin-
		 gular;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,j,k,i0,j0;
      _r_e_a_l factor,max,detfac,twofac;
      _i_n_t_e_g_e_r _a_r_r_a_y permute[1:n];
      m:=n+m;
      detfac := 1;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _b_e_g_i_n
	 max := 0;
	 _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 _b_e_g_i_n
	    max:=max+A[i,j]|&2
	 _e_n_d _f_o_r;
	 _i_f max>1 Ł max < .25 _t_h_e_n
	 _b_e_g_i_n
	    twofac := 2|&(-entier(ln(max)/1.3863+1));
	    _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l m _d_o
	    _b_e_g_i_n
	       A[i,j]:=A[i,j]*twofac
	    _e_n_d _f_o_r;
	    detfac:=detfac/twofac
	 _e_n_d
      _e_n_d equilibrium;
      _f_o_r k:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _b_e_g_i_n
	 max := 0;
	 _f_o_r i:=k _s_t_e_p 1 _u_n_t_i_l n _d_o
	 _f_o_r j:=k _s_t_e_p 1 _u_n_t_i_l n _d_o
	 _b_e_g_i_n
	    factor := abs(A[i,j]);
	    _i_f max _< factor _t_h_e_n
	    _b_e_g_i_n
	       max := factor;
	       i0 := i;
	       j0 := j;
	    _e_n_d
	 _e_n_d _f_o_r;
	 _i_f max _< '-8 _t_h_e_n _g_o _t_o exit;
	 max := A[i0,j0];
	 detfac := detfac*max;
	 _i_f i0 |= k _t_h_e_n
	 _b_e_g_i_n
	    detfac := -detfac;
	    _f_o_r j:=k _s_t_e_p 1 _u_n_t_i_l m _d_o
	    _b_e_g_i_n
	       factor := A[k,j];
	       A[k,j] := A[i0,j];
	       A[i0,j] := factor
	    _e_n_d _f_o_r
	 _e_n_d interchange of rows;
	 permute[k] := j0;
	 _i_f j0 |= k _t_h_e_n
	 _b_e_g_i_n
	    detfac := -detfac;
	    _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	    _b_e_g_i_n
	       factor := A[i,k];
	       A[i,k] := A[i,j0];
	       A[i,j0] := factor
	    _e_n_d _f_o_r
	 _e_n_d interchange of columns;
	 _f_o_r i:=k+1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 _b_e_g_i_n
	    factor := A[i,k]/max;
	    _i_f factor |= 0 _t_h_e_n
	    _f_o_r j:=k+1 _s_t_e_p 1 _u_n_t_i_l m _d_o
	    A[i,j]:=A[i,j]-A[k,j]*factor
	 _e_n_d _f_o_r
      _e_n_d for k;
      _f_o_r k:=n+1 _s_t_e_p 1 _u_n_t_i_l m _d_o
      _f_o_r i:=n _s_t_e_p -1 _u_n_t_i_l 1 _d_o
      _b_e_g_i_n
	 factor := A[i,k];
	 _f_o_r j:=i+1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 factor := factor-A[i,j]*A[j,k];
	 A[i,k] := factor/A[i,i]
      _e_n_d _f_o_r;
      _i_f m|=n _t_h_e_n
      _b_e_g_i_n
	 _f_o_r i:=n-1 _s_t_e_p -1 _u_n_t_i_l 1 _d_o
	 _b_e_g_i_n
	    i0 := permute[i];
	    _i_f i0|=i _t_h_e_n
	    _f_o_r k:=n+1 _s_t_e_p 1 _u_n_t_i_l m _d_o
	    _b_e_g_i_n
	       factor := A[i,k];
	       A[i,k] := A[i0,k];
	       A[i0,k] := factor
	    _e_n_d _f_o_r
	 _e_n_d
      _e_n_d interchange of solutions;
      Det Gauss := detfac
   _e_n_d Det Gauss;
   _r_e_a_l _p_r_o_c_e_d_u_r_e DET(A,n);
   _v_a_l_u_e n;
   _a_r_r_a_y A;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,p,j;
      _r_e_a_l z,temp,b;
      z:=1;
L:    p:=1;
      _f_o_r i:=2 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _i_f abs(A[i,1])>abs(A[p,1]) _t_h_e_n p:=i;
      _i_f n>1 & p|=1 _t_h_e_n
      _b_e_g_i_n
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 _b_e_g_i_n
	    temp:=A[1,j];
	    A[1,j]:=A[p,j];
	    A[p,j]:=temp
	 _e_n_d;
	 z:=-z
      _e_n_d;
      b:=A[1,1];
      z:=z*b;
      _i_f z|=0 & n>1 _t_h_e_n
      _b_e_g_i_n
         _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 A[i,j]:=A[i,j]-A[i,1]/b*A[1,j];
	 n:=n-1;
         _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
         _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
	 A[i,j]:=A[i+1,j+1];
	 _g_o_t_o L
      _e_n_d
      _e_l_s_e
      DET:=z
   _e_n_d DET;
   _i_n_t_e_g_e_r n;
   select(16);
L: n:=read integer;
   _i_f n>1 _t_h_e_n
   _b_e_g_i_n
      _a_r_r_a_y A,B[1:n,1:n];
      _i_n_t_e_g_e_r i,j;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      A[i,j]:=B[i,j]:=read real;
      writecr;
      write(|<  -dddddd.dd|>,Det Gauss(n,0,A,bad),DET(B,n));
      _g_o_t_o L;
bad:  writecr;
      writetext(|<<Error in Det Gauss|>);
      _g_o_t_o L
   _e_n_d
_e_n_d;
run<
3
-2, 2, -3
-1, 1, 3
2, 0, -1
4
2,5,3,5
4,6,6,3
11,3,2,-2
4,-7,9,3
4,
2,5,3,5
14,9,6,7
4,9,3,2
3,7,8,6
-1
