   _c_o_m_m_e_n_t

   https://projecteuler.net/problem=40

   Answer:  210
   Time:    7590.13s = 2h 6m 30.13s

   Punch numbers on (9 rolls of) paper tape, and read characters again.
   ;
   _r_e_a_l clock;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   _i_n_t_e_g_e_r n,digits,d,i,prod,limit;
   clock count;
   digits:=0;
   d:=1;
   limit:=10;
   select(32);
   _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 1000000 _d_o
   _b_e_g_i_n
      writeinteger(|<p|>,i);
      _i_f i=limit _t_h_e_n
      _b_e_g_i_n
         d:=d+1;
	 limit:=limit*10
      _e_n_d;
      digits:=digits+d;
      _i_f digits>1000000 _t_h_e_n _g_o_t_o out
   _e_n_d _f_o_r;
out:
   select(17);
   lyn;
   select(16);
   digits:=0;
   prod:=1;
   _f_o_r i:=1,10,100,1000,10000,100000,1000000 _d_o
   _b_e_g_i_n
      _f_o_r d:=d _w_h_i_l_e digits<i _d_o
      _b_e_g_i_n
         d:=lyn;
	 digits:=digits+1
      _e_n_d _f_o_r;
      _i_f d=16 _t_h_e_n d:=0;
      prod:=prod*d
   _e_n_d for i;
   writecr;
   writeinteger(|<p|>,prod);
   clock:=clock count;
   writecr;
   write(|<dddddddd.dd|>,clock)
_e_n_d;
