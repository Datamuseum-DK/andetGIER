start,image<
slip<
i=10
_b a50,b50,c50
;
;	KA=0:
;
;	Fill drum tracks 1-319 with qq <trackno>
;
;	KA=1:
;
;	Verify tracks 1-319
;
;	If a mismatch is found, print number read in and expected number,
;	continue with next track
;
;	Tracks are written and read in reverse.
;
;	KB: Stop before each pass
;
     hv  ra1
b1:  qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qq
     qqf
b2=600                     ; read buffer
a1:  zq                LKB ; start: _i_f kb on _t_h_e_n stop;
     vy  16                ; select(16);
     hv ra2            LKA ; _i_f -,ka on _t_h_e_n _b_e_g_i_n
     pp  319               ; p:=319;
a4:  it rb1-1  , pa ra3    ; write loop:
a3:  arn  _0    t  1    IPC ; PC:=marks b1
     grn (ra3)             ; clear cell
     it  p     , pa (ra3)  ; insert p into bits 0-9
     hv ra3            NPB ; _i_f -,f mark _t_h_e_n loop
     pi  p                 ; indicator:=p;
     vk  p     , sk rb1    ; write track(p);
     vk  p     , pp p-1    ; wait; p:=p-1;
     ncn p     , hv ra4    ; _i_f p |= 0 _t_h_e_n _g_o_t_o write loop;
     hv  ra1               ; _g_o_t_o start;
a2:                        ; _e_n_d write block _e_l_s_e _b_e_g_i_n
     pp  319               ; p:=319;
a5:  pi  p     , vk  p     ; read loop: indicator:=p;
     lk  b2    , vk  p     ; read track(p);
     it  b2-1  , pa ra6    ; _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 39 _d_o _b_e_g_i_n
a6:  arn _0     t  1    IPC ; R:=buffer[i]; PC:=marks;
     ca  p     , hv ra7    ; _i_f Raddr|=p _t_h_e_n _b_e_g_i_n
     ga  ra9               ; 
     sy  64                ; writecr;
a9:  qq  _0     , hs  rc0  ; write(Raddr);
     qq  p     , hs  rc0   ; write(p);
     hv  ra8               ; _g_o_t_o next track _e_n_d mismatch;
a7:  hv  ra6           NPB ; _e_n_d i;
a8:  pp  p-1               ; next track: p:=p-1;
     ncn p     , hv  ra5   ; _i_f p |= 0 _t_h_e_n _g_o_t_o read loop;
     hv  ra1               ; _g_o_t_o start;
;
;    qq <number>, hs rc0
;
;    Print <number>
;
;    Code from HELP3
;
c0:  arn (s0)  D
     ck  -30,pa rc7
     pa rc5
     dk  rc1  XV
c3:  sy  _0 , it 16
c4:  pa  rc7 , it -128
c5:  bt  _0 , hv rc9
c6:  mln rc2, tk 30
c7:  ar  _0 D LZ
     hh  rc4  LZ
c8:  qq 0 t 1
     ga rc3, hv rc3
c9:  sy 0
     qq (rc8) t1
     bs (rc8) t66
     pa rc8
     hr s1
c1:  qq  9999.39
c2:  qq  10.39
; binout,_010..98<
_e a1
