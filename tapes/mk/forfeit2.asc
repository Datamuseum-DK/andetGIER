algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r A1,A2,A3,A4,A5,A6,A7,A8,A9,K,X1,X2,X3,X4,Q,Z;
   _r_e_a_l S,T;
   _i_n_t_e_g_e_r numbers;

   K:=6;
   Z:=-1;
   numbers:=0;

   select(17);
   writecr;

   _f_o_r A9:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A8:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A7:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A6:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A5:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A4:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A3:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A2:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _f_o_r A1:=0 _s_t_e_p 1 _u_n_t_i_l 9 _d_o
   _b_e_g_i_n
      Z:=Z+1;
      K:=K+1;
      X1:=7*entier(K/7);
      K:=K-X1;
      Q:=(A1+A2+A3+A4+A5+A6+A7+A8+A9);
      S:=Q/7;
      X2:=7+sign(S-entier(S));
      T:=Q/10;
      X3:=entier(T);
      X4:=Q-10*entier(T);
      _i_f X1 |= 7 & X2 |= 7 & X3 |= 7
         & X4 |= 7 & A1 |= 7 & A2 |= 7
         & A3 |= 7 & A4 |= 7 & A5 |= 7
         & A6 |= 7 & A7 |= 7 & A8 |= 7
	 & A9 |= 7 _t_h_e_n
      _b_e_g_i_n
         write(|<dddd|>,Z);
	 numbers:=numbers+1;
	 _i_f numbers _m_o_d 10=0 _t_h_e_n writecr
      _e_n_d;
      _i_f Z=100 _t_h_e_n _g_o_t_o finish
   _e_n_d;
finish: _e_n_d;
run<

