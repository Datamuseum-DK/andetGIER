         IS PRIME := _f_a_l_s_e
      _e_n_d
      _e_l_s_e _i_f  p = n _t_h_e_n _b_e_g_i_n
         _i_f kbon _t_h_e_n _b_e_g_i_n
            IS PRIME DEBUG 2( n )
         _e_n_d;
         IS PRIME := _t_r_u_e
      _e_n_d
      _e_l_s_e _b_e_g_i_n
         IS PRIME := Pocklington( n, tdSteps, pbrSteps )
      _e_n_d
   _e_n_d IS PRIME;

   _p_r_o_c_e_d_u_r_e TEST7( n );
      _v_a_l_u_e n;
      _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e TEST7act( descr, p, e, q );
         _v_a_l_u_e p, e, q;
         _s_t_r_i_n_g descr;
