   _e_n_d FACTOR;

   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e IS PRIME( n, tdSteps, pbrSteps );
      _c_o_m_m_e_n_t Test n for primality using Pocklington criterion using factors of n-1;
      _v_a_l_u_e n, tdSteps, pbrSteps;
      _i_n_t_e_g_e_r n;
      _i_n_t_e_g_e_r tdSteps;
      _i_n_t_e_g_e_r pbrSteps;
   _b_e_g_i_n
      _i_n_t_e_g_e_r p;
      p := TRIAL DIVIDE( 1, 1 + tdSteps, n );
      _i_f p < n & n _m_o_d p = 0 _t_h_e_n _b_e_g_i_n
         _i_f kbon _t_h_e_n _b_e_g_i_n
            IS PRIME DEBUG 1( p, n )
