         _i_n_t_e_g_e_r e;
         _i_n_t_e_g_e_r q;
      _b_e_g_i_n
         _i_f kbon _t_h_e_n _b_e_g_i_n
            TEST7act DEBUG 1( descr, p, e, q )
         _e_n_d;
         factorCount := factorCount + 1;
