algol,_n<
_b_e_g_i_n
   _i_n_t_e_g_e_r n;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   n := 160000;
   select(17);
   writecr;
   _b_e_g_i_n
      _b_o_o_l_e_a_n _a_r_r_a_y A[0:(n-1)_:40];
      _i_n_t_e_g_e_r i,i1,i2,j,nprime,step;
      _r_e_a_l clock;
      clock count;
      _f_o_r i:=(n-1)_:40 _s_t_e_p -1 _u_n_t_i_l 0 _d_o
      A[i]:=_t_r_u_e;

      A[0] := A[0] & -, _1 1;

      _f_o_r step:=2,3,step+2 _w_h_i_l_e step*step<n _d_o
      _f_o_r i:=step*2 _s_t_e_p step _u_n_t_i_l n _d_o
      _b_e_g_i_n
	 i1:=i-1;
	 i2:=i1 _: 40;
	 A[i2] := A[i2] & (_1 0 _3_9 m _s_h_i_f_t -(i1 _m_o_d 40));
      _e_n_d _f_o_r;
      clock := clock count;
      nprime := 0;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _b_e_g_i_n
         _i_f A[(i-1)_:40] _s_h_i_f_t ((i-1) _m_o_d 40) _t_h_e_n
	 _b_e_g_i_n
	    write integer(|<dddddd|>, i);
	    nprime := nprime+1;
	    _i_f nprime _m_o_d 10=0 _t_h_e_n writecr;
	 _e_n_d is prime
      _e_n_d for print;
      writecr;
      write integer(|<p|>,nprime);
      writecr;
      write(|<ddddd.d|>, clock)
   _e_n_d inner block
_e_n_d;
