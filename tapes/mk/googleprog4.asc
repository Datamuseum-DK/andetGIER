algol,_n<
_b_e_g_i_n
   _i_n_t_e_g_e_r posx,posy,ny posx,ny posy,max løkke1,max løkke2,løkke1,løkke2,retning,tilbage;
   _r_e_a_l clock;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   _b_o_o_l_e_a_n _a_r_r_a_y gulerødder[1:5,1:5];
   _b_o_o_l_e_a_n _a_r_r_a_y lovlig[0:6,0:6];
   _p_r_o_c_e_d_u_r_e generer lovlig;
   _b_e_g_i_n
      _b_o_o_l_e_a_n l;
      _f_o_r ny posx:=0 _s_t_e_p 1 _u_n_t_i_l 6 _d_o
      _f_o_r ny posy:=0 _s_t_e_p 1 _u_n_t_i_l 6 _d_o
      _b_e_g_i_n
         l:=_t_r_u_e;
	 _i_f ny posx<1 £ ny posx>5 _t_h_e_n l := _f_a_l_s_e
	 _e_l_s_e
	 _i_f ny posy<1 £ ny posy>5 _t_h_e_n l := _f_a_l_s_e
	 _e_l_s_e
	 _i_f (ny posy=1 £ ny posy=5) & (ny posx=1 £ ny posx=5) _t_h_e_n l:=_f_a_l_s_e;
	 lovlig[ny posx,ny posy]:=l
      _e_n_d
   _e_n_d generer lovlig;
   _p_r_o_c_e_d_u_r_e nulstil gulerødder;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,j;
      tilbage:=12;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
      gulerødder[i,j] := _f_a_l_s_e;
      _f_o_r i:=2 _s_t_e_p 1 _u_n_t_i_l 4 _d_o
      _b_e_g_i_n
         gulerødder[1,i] := _t_r_u_e;
	 gulerødder[5,i] := _t_r_u_e;
	 gulerødder[i,1] := _t_r_u_e;
	 gulerødder[i,5] := _t_r_u_e
      _e_n_d
   _e_n_d nulstil gulerødder;
   _p_r_o_c_e_d_u_r_e check gulerødder;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,j;
      _i_f gulerødder[posy,posx] _t_h_e_n
      _b_e_g_i_n
	 gulerødder[posy,posx]:=_f_a_l_s_e;
	 tilbage:=tilbage-1
      _e_n_d;
      _i_f tilbage=0 _t_h_e_n
      _b_e_g_i_n
         writecr;
	 writetext(|<<Løsning fundet: |>);
	 write(|<dddd|>,max løkke1, max løkke2);
	 _g_o_t_o næste
      _e_n_d løsning
   _e_n_d check gulerødder;
   _p_r_o_c_e_d_u_r_e fremad;
   _b_e_g_i_n
      ny posx := posx;
      ny posy := posy;
      _c_a_s_e retning _o_f
      _b_e_g_i_n
         ny posy:=ny posy-1;
	 ny posx:=ny posx-1;
	 ny posy:=ny posy+1;
	 ny posx:=ny posx+1
      _e_n_d retning;
      _i_f lovlig[ny posy,ny posx] _t_h_e_n
      _b_e_g_i_n
         posx := ny posx;
	 posy := ny posy;
	 check gulerødder
      _e_n_d lovlig
   _e_n_d fremad;
   _p_r_o_c_e_d_u_r_e venstre;
   retning := (retning) _m_o_d 4+1;
   _p_r_o_c_e_d_u_r_e højre;
   retning := (retning+2) _m_o_d 4+1;
   clock count;
   generer lovlig;
   _f_o_r max løkke1:=1 _s_t_e_p 1 _u_n_t_i_l 1000 _d_o
   _f_o_r max løkke2:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
   _b_e_g_i_n
      _i_f kbon _t_h_e_n
      _b_e_g_i_n
         writecr;
	 write(|<ddddd|>,max løkke1,max løkke2)
      _e_n_d;
      posx := 3;
      posy := 3;
      retning := 1;
      nulstil gulerødder;
      _f_o_r løkke1:=1 _s_t_e_p 1 _u_n_t_i_l max løkke1 _d_o
      _b_e_g_i_n
	 _f_o_r løkke2:=1 _s_t_e_p 1 _u_n_t_i_l max løkke2 _d_o
	 _b_e_g_i_n
	    fremad;
	    venstre
	 _e_n_d løkke2;
         højre;
      _e_n_d;
næste:
   _e_n_d max løkke2 og max løkke1;
   clock := clock count;
   writecr;
   write(|<dddddd.dd|>, clock)
_e_n_d;
t<

