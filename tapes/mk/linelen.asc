   maxlinelen:=0;

   _f_o_r c:=lyn _w_h_i_l_e c|=12 _d_o
   _b_e_g_i_n
      _i_f c=64 _t_h_e_n
      _b_e_g_i_n
         _i_f linelen>maxlinelen & pageno _m_o_d 2=1 _t_h_e_n
