_b_e_g_i_n
   _a_r_r_a_y A[0:39];
   _i_n_t_e_g_e_r kanal,i,dtop;
   dtop:=tromleplads;
   skrvvr;
   skrvtekst(|<<tromleplads: |>);
   skrv(|<ndddddd|>,tromleplads);
   kanal:=(tromleplads-39)_:40;
   _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 39 _d_o A[i]:=i;
   _f_o_r i:=kanal _s_t_e_p -1 _u_n_t_i_l 0 _d_o
   _b_e_g_i_n
      skrvvr;
      tromleplads:=i*40+39;
      skrv(|<nddddd|>,i,tromleplads);
      til tromle(A);
      skrvtekst(|<< OK|>)
   _e_n_d
_e_n_d;

