a28: ar  pd1           IRC ; R:=d1[p]; RC:=marks;
     ar  2     D       LRA ; _i_f RA _t_h_e_n R:=R+2.9;
     ar  1     D       LRB ; _i_f RB _t_h_e_n R:=R+1.9;
     pp  p1                ; p:=p+1;
a27: bt  39    t -1        ; loop 40 times
     hv  a28
     ar  c3    , ck  0     ; R:=R+reltrack.9; R00:=0;
     hv  a32           NZ  ; _i_f R=0 _t_h_e_n _b_e_g_i_n
     qq (c3)   t 1         ; reltrack:=reltrack+1;
     pp  a30
