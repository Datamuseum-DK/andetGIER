a29: _ttrack: ;
a30: _tsum ok;
a31: _k 29 _tsum fail; 62.
a25: arn  c4   , ck -10    ; Rtćl:=initial reltrack;
     ar  (b4) D            ; Raddr:=catalog;
     zq                    ; STOP; R:=read integer;
     ga  b4    , ga  a26   ; catalog:=Raddr; checktrack:=Raddr
     ck  10    , ga  c4    ; initial reltrack:=Rtćl;
     qq (a26)  t -1        ; checktrack:=checktrack-1;
