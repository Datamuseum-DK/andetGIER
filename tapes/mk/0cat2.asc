a32: pp  a31               ; writetext(|<<_r_e_dsum fail_b_l_a_c_k|>);
     hs  b30
     sy  64                ; writecr;
     pa  b5    t d1-1      ; reset address
     it  e10   , pa  a6    ;
     vk (b4)   , lk  d1    ; read
     vk (b4)               ; wait
