     gr  c3    , grn c2    ; reltrack:=initial reltrack; checksum:=0;
a2:  hs  b1                ; loop: nextcell;
a4:  hv  a2            NRA ; loop2: _i_f -,RA _t_h_e_n _g_o_t_o loop;
