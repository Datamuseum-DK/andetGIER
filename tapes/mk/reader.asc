    write ( |<-dddddd.ddd|>, atime[0,0], atime[1,0], atime[2,0]); writecr;

    _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
    _b_e_g_i_n
        writetext(|<<Repeat seconds       |>);
