    _f_o_r i := 7 _s_t_e_p 1 _u_n_t_i_l 11 _d_o
    _b_e_g_i_n
        writetext(|<<Repeat seconds       |>);
        write ( |<-dddddd.ddd|>, atime[0,i], atime[1,i], atime[2,i], atime[3,i]);
        writecr;
    _e_n_d;
