        mp1 := 0;
        m := 0;

        dtemp := ZERO;

        _i_f (n _< 0) _t_h_e_n
        _b_e_g_i_n
          ddot := ZERO;
          _g_o_t_o return;
        _e_n_d;

        _i_f (incx |= 1 Ł incy |= 1) _t_h_e_n
        _b_e_g_i_n

                _c_o_m_m_e_n_t
                /* code for unequal increments or equal increments
                   not equal to 1                                       */;

                ix := 0;
                iy := 0;
                _i_f (incx < 0) _t_h_e_n ix := (-n+1)*incx;
                _i_f (incy < 0) _t_h_e_n iy := (-n+1)*incy;
