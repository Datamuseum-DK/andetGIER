                _b_e_g_i_n
                        dtemp := dtemp + dx[sx+ix]*dy[sy+iy];
                        ix := ix + incx;
                        iy := iy + incy;

                _e_n_d;
                ddot := dtemp;
                _g_o_t_o return;
        _e_n_d;


_c_o_m_m_e_n_t
/* code for both increments equal to 1 */
ROLLED VERSION ;

        _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l n-1 _d_o
        _b_e_g_i_n
                dtemp := dtemp + dx[sx+i]*dy[sy+i];
