_b_e_g_i_n
   _i_n_t_e_g_e_r i,j,i5;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _b_e_g_i_n
      _r_e_a_l clock;
      _b_o_o_l_e_a_n code;
      _c_o_m_m_e_n_t
      Pack the following instruction into code:

      zl,  hr s1
      62   17
      ;
      pack(code, 0, 41, 0);
      pack(code,
            0,  9,  0,
           10, 19,  1,
	   20, 25, 62,
	   30, 35, 17,
	   39, 39,  1,
	   40, 40,  1);
      clock count:=gier(code)
   _e_n_d;
   i5:=5;
   _f_o_r i:=400 _s_t_e_p 10 _u_n_t_i_l 690,
             691 _s_t_e_p 1 _u_n_t_i_l 700 _d_o
   _b_e_g_i_n
      _a_r_r_a_y A[1:i];
      clock count;
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l i _d_o
      _b_e_g_i_n
      A[i] := sin(j)+exp(-j)+arctan(1/j)+ln(j)+sqrt(j)+i5|&i5;
      _e_n_d;
      writecr;
      write(|<dddd|>, i);
      write(|<nd.ddddd|>, clock count/i)
   _e_n_d for i;
_e_n_d;

