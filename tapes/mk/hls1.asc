algol<
_b_e_g_i_n
   _r_e_a_l r,g,b,min,max,h,l,s;
   char:=0;
   select(16);
again:
   r:=read real/255;
   g:=read real/255;
   b:=read real/255;
   min:=max:=r;
   _i_f g>max _t_h_e_n max:=g;
   _i_f g<min _t_h_e_n min:=g;
   _i_f b>max _t_h_e_n max:=b;
   _i_f b<min _t_h_e_n min:=b;
   h:=_i_f max=min _t_h_e_n 0 _e_l_s_e
      _i_f max=r   _t_h_e_n 60*(0+(g-b)/(max-min)) _e_l_s_e
      _i_f max=g   _t_h_e_n 60*(2+(b-r)/(max-min)) _e_l_s_e
                            60*(4+(r-g)/(max-min));
   s:=_i_f max=0 _t_h_e_n 0 _e_l_s_e
      _i_f min=1 _t_h_e_n 0 _e_l_s_e
      (max-min)/(1-abs(max+min-1));
   l:=(max+min)/2;
   writecr;
   write(|<dddd|>,r*255,g*255,b*255);
   writetext(|<<  |>);
   write(|< -ddd.dddd|>,h,l,s);
   _i_f char|=11 _t_h_e_n _g_o_t_o again
_e_n_d;
run<
128,0,0
204,31,31
230,57,57
255,82,82
255,124,124
255,181,181
255,142,82
255,178,0
255,217,0
