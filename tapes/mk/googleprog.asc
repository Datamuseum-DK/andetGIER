algol,_n_i<
_b_e_g_i_n
   _i_n_t_e_g_e_r posx,posy,ny posx,ny posy,max lřkke1,max lřkke2,lřkke1,lřkke2,retning;
   _r_e_a_l clock;
   _r_e_a_l _p_r_o_c_e_d_u_r_e clock count;
   _c_o_d_e clock count;
   1, 37;
     zl        , grf p-1   ; RF:=clock count; stack[p-1]:=RF;
   _e;
   _i_n_t_e_g_e_r _a_r_r_a_y gulerřdder[1:5,1:5];
   _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e lovlig;
   _b_e_g_i_n
      lovlig := _t_r_u_e;
      _i_f ny posx<1 Ł ny posx>5 _t_h_e_n lovlig := _f_a_l_s_e
      _e_l_s_e
      _i_f ny posy<1 Ł ny posy>5 _t_h_e_n lovlig := _f_a_l_s_e
      _e_l_s_e
      _i_f (ny posy=1 Ł ny posy=5) & (ny posx=1 Ł ny posx=5) _t_h_e_n lovlig:=_f_a_l_s_e
   _e_n_d lovlig;
   _p_r_o_c_e_d_u_r_e nulstil gulerřdder;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,j;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
      gulerřdder[i,j] := 0;
      _f_o_r i:=2 _s_t_e_p 1 _u_n_t_i_l 4 _d_o
      _b_e_g_i_n
         gulerřdder[1,i] := 1;
	 gulerřdder[5,i] := 1;
	 gulerřdder[i,1] := 1;
	 gulerřdder[i,5] := 1
      _e_n_d
   _e_n_d nulstil gulerřdder;
   _p_r_o_c_e_d_u_r_e check gulerřdder;
   _b_e_g_i_n
      _i_n_t_e_g_e_r n,i,j;
      gulerřdder[posy,posx]:=0;
      n:=0;
      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
      _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
      n:=n+gulerřdder[i,j];
      _i_f n=0 _t_h_e_n
      _b_e_g_i_n
         writecr;
	 writetext(|<<Lřsning fundet: |>);
	 write(|<dddd|>,max lřkke1, max lřkke2);
	 _g_o_t_o nćste
      _e_n_d lřsning
   _e_n_d check gulerřdder;
   _p_r_o_c_e_d_u_r_e fremad;
   _b_e_g_i_n
      ny posx := posx;
      ny posy := posy;
      _c_a_s_e retning _o_f
      _b_e_g_i_n
         ny posy:=ny posy-1;
	 ny posx:=ny posx-1;
	 ny posy:=ny posy+1;
	 ny posx:=ny posx+1
      _e_n_d retning;
      _i_f lovlig _t_h_e_n
      _b_e_g_i_n
         posx := ny posx;
	 posy := ny posy;
	 check gulerřdder
      _e_n_d lovlig
   _e_n_d fremad;
   _p_r_o_c_e_d_u_r_e venstre;
   retning := (retning) _m_o_d 4+1;
   _p_r_o_c_e_d_u_r_e hřjre;
   retning := (retning+2) _m_o_d 4+1;
   clock count;
   _f_o_r max lřkke1:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
   _f_o_r max lřkke2:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
   _b_e_g_i_n
      posx := 3;
      posy := 3;
      retning := 1;
      nulstil gulerřdder;
      _f_o_r lřkke1:=1 _s_t_e_p 1 _u_n_t_i_l max lřkke1 _d_o
      _b_e_g_i_n
	 _f_o_r lřkke2:=1 _s_t_e_p 1 _u_n_t_i_l max lřkke2 _d_o
	 _b_e_g_i_n
	    fremad;
	    fremad;
	    venstre
	 _e_n_d lřkke2;
         venstre;
      _e_n_d;
nćste:
   _e_n_d max lřkke2 og max lřkke1;
   clock := clock count;
   writecr;
   write(|<dddddd.dd|>, clock)
_e_n_d;
t<

