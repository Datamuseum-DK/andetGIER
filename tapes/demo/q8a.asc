algol<
8 Dronninger.
_b_e_g_i_n
   _i_n_t_e_g_e_r _a_r_r_a_y qcolumn[1:8];
   _i_n_t_e_g_e_r _a_r_r_a_y solutions[1:100];
   _i_n_t_e_g_e_r i, nsol;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e mirror1(a);
   _v_a_l_u_e a;
   _i_n_t_e_g_e_r a;
   _b_e_g_i_n
      _i_n_t_e_g_e_r ma,i;

      ma := 0;

      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
      _b_e_g_i_n
         ma := ma*10+(a _m_o_d 10);
         a := a _: 10
      _e_n_d;

      mirror1 := ma
   _e_n_d mirror1;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e mirror2(a);
   _v_a_l_u_e a;
   _i_n_t_e_g_e_r a;
   mirror2 := 99999999-a;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e rotate(a);
   _v_a_l_u_e a;
   _i_n_t_e_g_e_r a;
   _b_e_g_i_n
      _i_n_t_e_g_e_r ra,i;

      ra := 0;

      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
      _b_e_g_i_n
         ra := ra + 10|&(8-(a _m_o_d 10))*i;
         a := a _: 10
      _e_n_d;

      rotate := ra
   _e_n_d rotate;

   _p_r_o_c_e_d_u_r_e testit(row, col);
   _v_a_l_u_e row, col;
   _i_n_t_e_g_e_r row, col;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i, j, testsol, row1, solution;
      _B_o_o_l_e_a_n bad;

      bad := _f_a_l_s_e;
      i := 0;
      _f_o_r i := i+1 _w_h_i_l_e i<row & -, bad _d_o
      _b_e_g_i_n
         row1 := qcolumn[i];
         bad := row1=col Ł row1=col-row+i Ł row1=col+row-i
      _e_n_d _f_o_r;

      _i_f -, bad _t_h_e_n
      _b_e_g_i_n
         qcolumn[row] := col;
         _i_f row=8 _t_h_e_n
         _b_e_g_i_n
            solution := 0;
            _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
            solution := solution*10 + qcolumn[i];
            bad := _f_a_l_s_e;
            i := 0;
            _f_o_r i := i+1 _w_h_i_l_e i_<nsol & -, bad _d_o
            _b_e_g_i_n
               j := -1;
               _f_o_r j := j+1 _w_h_i_l_e j_<7 & -, bad _d_o
               _b_e_g_i_n
                  testsol := solutions[i];
                  _i_f (_B_o_o_l_e_a_n j) _s_h_i_f_t -1 _t_h_e_n testsol := rotate(testsol);
                  _i_f (_B_o_o_l_e_a_n j) _s_h_i_f_t -2 _t_h_e_n testsol := mirror1(testsol);
                  _i_f (_B_o_o_l_e_a_n j) _s_h_i_f_t -3 _t_h_e_n testsol := mirror2(testsol);
                  bad := testsol = solution
               _e_n_d;
            _e_n_d;
            _i_f -, bad _t_h_e_n
            _b_e_g_i_n
               nsol := nsol+1;
               solutions[nsol] := solution;
               writecr;
               writetext(|<<Lřsning nr. |>);
               write integer(|<dd|>, nsol);
               writecr;
               _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
               _b_e_g_i_n
                  writetext(|<<+-+-+-+-+-+-+-+-+|>);
                  writecr;
                  _f_o_r j:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
                  _b_e_g_i_n
                     writechar(60); writechar(14); writechar(0);
                     writechar(_i_f qcolumn[i]=j _t_h_e_n 40 _e_l_s_e 0);
                     writechar(58)
                  _e_n_d;
                  writechar(60); writechar(14); writechar(0); writechar(58);
                  writecr
               _e_n_d;
               writetext(|<<+-+-+-+-+-+-+-+-+|>);
               writecr;
               _i_f nsol _m_o_d 3=0 _t_h_e_n writechar(72)
            _e_n_d
         _e_n_d
         _e_l_s_e
         _b_e_g_i_n
            _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
            testit(row+1, i)
         _e_n_d
      _e_n_d
   _e_n_d testit;

   select(16);

   nsol := 0;
   _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
   testit(1, i);

   writecr;
   writetext(|<<Antal lřsninger: |>);
   write integer(|<dd|>, nsol);
   writecr
_e_n_d;
t<

