      writetext(|<<
Flygtede mange tibetanere hertil under krigen Tibet  - Kina.|>);
      _i_f svar _t_h_e_n _b_e_g_i_n spm:=spm+1; writetext(|<<
Hedder ministerpræsidenten NEHRU.|>);
      lt:=_i_f svar _t_h_e_n 41 _e_l_s_e 67; _g_o _t_o TY;
      _e_n_d; spm:=spm+1; writetext(|<<
Nord for Hong Kong.|>);
      _i_f svar _t_h_e_n _b_e_g_i_n lt:=98; _g_o _t_o TY;
      _e_n_d; spm:=spm+1;
      writetext(|<<
Består landet kun af een by.|>);
      lt:=_i_f svar _t_h_e_n 92 _e_l_s_e 99;
      _g_o _t_o TY;


FÆRDIG:tæller[lt]:=tæller[lt]+1;
writetext(|<<
Det var GIER på det |>); write(|<ndd|>,spm); writetext(|<<.spørgsmål|>);
_g_o _t_o LOUT;
FEJL:
writetext(|<<
Desværre er der svaret galt på et eller flere af de stillede spørgsmål.
Se disse igennem og prøv igen.|>);
LOUT:
