      _e_n_d if newlineq;
MM:   LINE;

_c_o_m_m_e_n_t



                                    -14-                                   DEMON-1E
;
      SHIFT(4);
      writetext(|<<Specify N: |>);
      N := read integer;
      LINE;
      _i_f N > 24 _t_h_e_n N := 24;
      _i_f N = 0 _t_h_e_n _g_o_ _t_o RESTART;
      _b_e_g_i_n _c_o_m_m_e_n_t inner LINEQ-block;
         _a_r_r_a_y x[1:N], MATRIX[1:N, 1:N + 1];
         _p_r_o_c_e_d_u_r_e  LINEQ1 (N, a, x, NOSOLUTION);
         _i_n_t_e_g_e_r  N;
         _a_r_r_a_y  a, x;
         _l_a_b_e_l  NOSOLUTION;
         _b_e_g_i_n
            _i_n_t_e_g_e_r p, i, j;
            _r_e_a_l  M;
