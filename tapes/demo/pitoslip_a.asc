slip<
[Calculation of PI

]

_b a50,b50,c50,d50,e50
i=10
e1=2     ; step: No. of tracks per register
e2=500   ; FREE: No. of first track to use on drum
b1=600   ; _i_n_t_e_g_e_r _a_r_r_a_y A[0:39]
b2=640   ; _i_n_t_e_g_e_r _a_r_r_a_y B[0:39]
b3=680   ; _i_n_t_e_g_e_r _a_r_r_a_y C[0:39]
b4=720   ; _i_n_t_e_g_e_r _a_r_r_a_y D[0:39]

_b a20                      ; Main block
d0:  arn c9                ; _b_e_g_i_n main program
     zq                    ; R:=default step; stop;
     gr  c9		   ; step:=R;
     vy  17                ; select(17);
     hs  d1                ; ASSIGN(6, asize, 0);
     qq  6.39
     qq  c3
     qq  0.39
     sy  64                ; writecr;
     hs  d2                ; PRINT(asize, 0);
     qq  c3
     qq  0.39
     hs  d3                ; DIVIDE(asize, 0, 7, out1);
     qq  c3
     qq  0.39
     qq  7.39
     qq  c10
     sy  64                ; writecr;
     hs  d2                ; PRINT(asize, 0);
     qq  c3
     qq  0.39
     hs  d4                ; COPY(asize, 0, t1size, 1);
     qq  c3
     qq  0.39
     qq  c4
     qq  1.39
     pa  a2    t 7
a1:  hs  d5                ; ADD(t1size, 1, asize, 0);
     qq  c4
     qq  1.39
     qq  c3
     qq  0.39
     sy  64                ; writecr;
     hs  d2                ; PRINT(asize, 0);
     qq  c3
     qq  0.39
a2:  bt  7     t -1
     hv  a1
     vk  0                 ; wait drum
     hr  d0                ; restart program
_e                         ; Main block

c1:  qq  1.39
c2:  qq  10000000000.39
c3:  qq  [asize]
c4:  qq  [t1size]
c5:  qq  [t2size]
c6:  qq  [t3size]
c7:  qq  [ssize]
c8:  qq  40.39
c9:  qq  e1.39		   ; step
c10: qq  [out1]
c11: qq  [out2]
c12: qq  [out3]
[
	_p_r_o_c_e_d_u_r_e ASSIGN(n, asize, na);

     hs  d1                ; Call ASSIGN
     qq  n.39              ; [s1| Value of n
     qq  <addr. of asize>  ; [s2| Address of asize
     qq  na.39             ; [s3| Value of na
                           ; Return to s+4
]
_b a10
d1:  pp  b1
     pa  a2    t 39        ; _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 39 _d_o
a1:  grn p     , pp  p1    ; A[i]:=0;
a2:  bt  39    t -1        ;
     hv  a1
     pm  s3
     mln c9    X           ; R:=na*step
     ck  30
     ar  e2    D           ; Raddr:=na*step+FREE
     ga  a3                ; nt:=Raddr;
     arn c9    , sr  c1    ;
     ck  30    , ga  a4
a3:  vk  _0     t 1        ; _f_o_r i:=step-1 _s_t_e_p -1 _u_n_t_i_l 0 _d_o
     sk  b1                ; _b_e_g_i_n put(A, FREE, nt); nt:=nt+1;
     bs  (a4)  t 0         ; _i_f i_<0 _t_h_e_n
     hv  a4                ;
     arn s1    , gr 39b1   ; A[39]:=n;
a4:  bt  [step] t -1   
     hv  a3                ; _e_n_d for i;
     arn s1                ; asize:=_i_f n=0 _t_h_e_n 0
     hv  a5            LZ
     pm  c8                ; _e_l_s_e step*40;
     mln c9    X
a5:  gr (s2)
     hr  s4
_e                          ; _e_n_d ASSIGN;
[
	_p_r_o_c_e_d_u_r_e PRINT(asize, na);

     hs  d2                ; Call PRINT
     qq  <addr. of asize>  ; [s1| Address of asize
     qq  na.39             ; [s2| Value of na
                           ; Return to s+3

			   ; Indicator:
			   ; PA: first
]
_b a20
d2:  pi  32    t 991       ; first := _t_r_u_e;
     grn a0                ; group:=0;
     pa  a10   t 39        ; c:=39;
     pm  c8                ;
     mln c9    X           ; R:=step*40;
     sr  c1    , gr  a1    ; count:=step*40-1;
     gr  a6                ; asize-1:=count;
     arn s2    , ar  c1    ; R:=na+1;
     xr                    ;
     mln c9    X           ; R:=(na+1)*step
     ck  30
     ar  1e2   D           ; Raddr:=na*step+FREE+1
     ga  a11               ; ta:=Raddr;
a11: vk  _0     t -1        ;
     lk  b1     , vk (a11) ; get(A, FREE, ta);
a12: bs (a10)   t -1       ; _i_f c_<-1 _t_h_e_n
     hv  a13
     pa  a10    t 39       ; c:=39;
     vk (a11)   t -1       ; ta:=ta-1;
     lk  b1     , vk (a11) ; get(A, FREE, ta);
a13: is (a10)   , arn sb1  ; R:=A[c];
     gr  a2     , arn a3   ; n:=R;
     gr  a4     , qqn      ; DIVISOR:=MODUL_:10; R:=0;
     ar  16     D      NPA ; _i_f -,PA _t_h_e_n Raddr:=16;
     ga  a16               ; space := _i_f first _t_h_e_n 0 _e_l_s_e 16;
     pa  a14    t 9        ; _f_o_r i:=9 _s_t_e_p -1 _u_n_t_i_l 0 _d_o
a15: pm  a2     , dln a4   ; M:=n _m_o_d DIVISOR; R:=n _: DIVISOR;
     gm  a2                ; n:=n _m_o_d DIVISOR;
     hv  a16           LZ  ; _i_f digit |= 0 _t_h_e_n
     ck  -10    , ga  r1   ;
     sy  _0                ; writechar(digit);
     pi  0      t 991      ; first:=_f_a_l_s_e;
     pa  a16    Vt 16      ; space:=16;
a16: sy  _0                ; _e_l_s_e writechar(space);
     arn a14    , ca 5     ; _i_f i=5 _t_h_e_n
     sy  0                 ; writechar(0);
     pm  a4     , dln a5   ; R:=DIVISOR_:10;
     gr  a4                ; DIVISOR:=R;
a14: bt  _0      t-1        ; _e_n_d for i;
     hv  a15
     arn a1     , sr  a6   ; R:=count-(asize-1);
     hv  a17           NZ  ; _i_f count=asize-1 _t_h_e_n _b_e_g_i_n
     sy  59                ; writetext(|<<.|>);
     pi  0      Vt 991      ; first := _f_a_l_s_e;
a17: sy  0                 ; _e_n_d _e_l_s_e writechar(0);
     arn a0     , ar  c1   ; R:=group+1;
     gr  a0     X          ; group:=R; M:=group;
     dln a7     X          ; R:=group _m_o_d 6;
     sy  64            LZ  ; _i_f R=0 _t_h_e_n writecr;
a10: qq  [c]    t -1       ; c:=c-1;
     arn a1     , sr  c1   ; count:=count-1;
     gr  a1
     hv  a12           NT  ; _e_n_d for count;
     hr  s3             

a0:  qq                    ; group
a1:  qq                    ; count
a2:  qq                    ; n
a3:  qq 1000000000.39      ; MODUL_:10
a4:  qq                    ; DIVISOR
a5:  qq 10.39              ; 10
a6:  qq 0                  ; asize-1
a7:  qq 6.39               ; 6 groups per line
_e                          ; _e_n_d PRINT;
[
	_p_r_o_c_e_d_u_r_e DIVIDE(asize, na, n, empty);

     hs  d3                ; Call DIVIDE
     qq  <addr. of asize>  ; [s1| Address of asize
     qq  na.39             ; [s2| Value of na
     qq  n.39              ; [s3| Value of n
     qq  <addr. of empty>  ; [s4| Address of empty
                           ; Return to s+5

			   ; Indicator:
			   ; PA: first
]
_b a20
d3:  pi  32    t 991       ; first := _t_r_u_e;
     grn a1                ; carry := 0;
     arn (s1)  , sr  c1    ; R:=asize-1;
     xr        , dln c8    ;
     ar  c1    , gr  a2    ; nt:=1+(asize-1)_:40;
     xr        , ck  30    ; Raddr:=(asize-1)_m_o_d 40;
     ga  a10               ; c:=Raddr;
     pm  s2
     mln c9    X           ; R:=na*step
     ar  a2    , ck  30    ; Raddr:=na*step+nt
     ar  1e2   D           ; Raddr:=na*step+FREE+1
     ga  a11               ; nt:=na*step+FREE+1
a11: vk  _0     t -1        ; nt:=nt-1; vk(nt);
     lk  b1    , vk (a11)  ; get(A, FREE, nt);
     lk  b2                ; timing test: get(B, FREE, nt);
a12: is (a10)  , arn sb1   ; R:=A[c];
     pm  a1    , ml  c2    ; RM:=(cell+carry*MODUL);
     dl  s3    , gm  a1    ; carry:=rem.
     is (a10)  , gr  sb1   ; A[c]:=quotient;
     hv  a10        NPA    ; _i_f first _t_h_e_n
     pi  0    Vt 991   NZ  ; _i_f cell>0 _t_h_e_n first:=_f_a_l_s_e
     arn c1    , sc  (s1)  ; _e_l_s_e asize:=asize-1;
a10: bt  _0     t -1       ;
     hv  a12
     sk  b1
     pa  a10   t 39        ; c:=39;
     arn a2    , sr  c1    ; R:=count-1;
     gr  a2                ; count:=R;
     hv  a11           NZ  ;
     pm  c1                ; M:=1;
     grn (s4)  , arn (s1)  ; empty:=_f_a_l_s_e; R:=asize;
     gm  (s4)          LZ  ; _i_f asize=0 _t_h_e_n empty:=_t_r_u_e;
     hr  s5

a1: qq			   ; carry
a2: qq			   ; nt
_e                          ; _e_n_d DIVIDE;
[
	_p_r_o_c_e_d_u_r_e COPY(asize, na, bsize, nb);

     hs  d4                ; Call COPY
     qq  <addr. of asize>  ; [s1| Address of asize
     qq  na.39             ; [s2| Value of na
     qq  <addr. of bsize>  ; [s3| Address of bsize
     qq  nb.39             ; [s4| Value of nb
                           ; Return to s+5

]
_b a20
d4:  pm  s2
     mln c9    X           ; R:=na*step
     ck  30
     ar  e2    D           ; Raddr:=na*step+FREE
     ga  a1                ; t1:=Raddr;
     pm  s4
     mln c9    X           ; R:=nb*step
     ck  30
     ar  e2    D           ; Raddr:=na*step+FREE
     ga  a2                ; t1:=Raddr;
     arn c9    ,  ck  30   ; Raddr:=step
     ga  a3
a1:  vk  [t1]  t 1         ; t1:=t1+1; vk(t1);
     lk  b1                ; get(A, FREE, t1);
a2:  vk  [t2]  t 1         ; t2:=t2+1; vk(t2);
     sk  b1                ; put(A, FREE, t2);
a3:  bt  [count]t -1       ;
     hv  a1
     arn (s1)   , gr  (s3) ; bsize:=asize;
     hr  s5
_e                          ; _e_n_d COPY;
[
	_p_r_o_c_e_d_u_r_e ADD(bsize, nb, asize, na);

     hs  d5                ; Call ADD
     qq  <addr. of bsize>  ; [s1| Address of bsize
     qq  nb.39             ; [s2| Value of nb
     qq  <addr. of asize>  ; [s3| Address of asize
     qq  na.39             ; [s4| Value of na
                           ; Return to s+5

]
_b a20
d5:  arn (s3)  , sr  c1    ; R:=asize-1;
     xr        , dln c8    ;
     ar  c1    , gr  a1    ; nt:=1+(asize-1)_:40;
     grn a2    , arn c1    ; carry := 0;
     gr  a3                ; count := 1;
     pt  a10   t 39        ; nc:=39;
     arn (s3)  , gr  a4    ; c2:=asize;
     grn  a5               ; c3:=0;
     grn (s3)              ; asize:=0;
     pm  s2
     mln c9    X           ; R:=nb*step
     ck  30
     ar  e2    D           ; Raddr:=nb*step+FREE
     ga  a11               ; t2:=Raddr;
     pm  s4
     mln c9    X           ; R:=na*step
     ck  30
     ar  e2    D           ; Raddr:=na*step+FREE
     ga  a12               ; t1:=Raddr;
a11: vk  [t2]  t 1         ;L1: t2:=t2+1; vk(t2)
     lk  b2                ; get(B, FREE, t2);
a12: vk  [t1]  t 1         ; t1:=t1+1; vk(t1);
     lk  b1    , vk (a12)  ; get(A, FREE, t1); waitfordrum;
     pp  0                 ; c1:=0;
a13: arn pb1   , ar  pb2   ;L2: R:=A[c1]+B[c1]+carry;
     ar  a2    , gr  pb1   ; A[c1]:=R;
     sr  c2                ; R:=R-MODUL;
     hv  a14           LT  ; _i_f R_>0 _t_h_e_n _b_e_g_i_n
     arn c1    , gr  a2    ; carry:=1;
     arn c2    , sc  pb1   ; A[c1]:=A[c1]-MODUL;
     hv  r2                ; _e_n_d _e_l_s_e
a14: grn a2                ; carry:=0;
     arn c1    , ar  a5    ; c3:=c3+1;
     gr  a5    X           ; M:=c3
     arn pb1               ; R:=A[c1];
     gm (s3)           NZ  ; _i_f R|=0 _t_h_e_n asize:=M;
     pp  p1                ; c1:=c1+1;
a10: bs  p     t  [nc]     ; _i_f c1_<nc _t_h_e_n _g_o_t_o L2;
     qq  V
     hv  a13
     arn a2
     hv  a15           LZ
     bs  p     t 39        ; _i_f p_<39 & carry |= 0 _t_h_e_n _g_o_t_o L2;
     qq  V
     hv  a13
a15: sk  b1                ; put(A, FREE, t1);
     arn a3    , ar  c1    ; count:=count+1;
     gr  a3    , sr  a1    ; _i_f count=nt _t_h_e_n
     hv  a16           NZ  ;
     arn a4    , sr  c1    ; R:=c2-1
     xr        , dln c8    ; 
     xr        , ck  20    ; Raddr := (c2-1) _m_o_d 40;
     gt  a10               ; nc := Rtćl;
a16: arn a2
     hv  a11           NZ  ; _i_f carry>0 _t_h_e_n _g_o_t_o L1;
     arn a1    , sr  a3    ; R:=nt-count;
     hv  a11           NT  ; _i_f R_>0 _t_h_e_n _g_o_t_o L1;
     hr  s5

a1:  qq                    ; nt
a2:  qq                    ; carry
a3:  qq                    ; count
a4:  qq                    ; c2
a5:  qq                    ; c3
_e                          ; _e_n_d ADD;
_e d0                       ; _e_n_d program;
