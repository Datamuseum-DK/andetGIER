a,pl<
8 Dronninger.
_b_e_g_i_n
   _i_n_t_e_g_e_r _a_r_r_a_y qcolumn[1:8];
   _i_n_t_e_g_e_r _a_r_r_a_y solutions[1:100];
   _i_n_t_e_g_e_r i, nsol;
   _r_e_a_l x,y,ssize;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e mirror1(a);
   _v_a_l_u_e a;
   _i_n_t_e_g_e_r a;
   _b_e_g_i_n
      _i_n_t_e_g_e_r ma,i;

      ma := 0;

      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
      _b_e_g_i_n
         ma := ma*10+(a _m_o_d 10);
         a := a _: 10
      _e_n_d;

      mirror1 := ma
   _e_n_d mirror1;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e mirror2(a);
   _v_a_l_u_e a;
   _i_n_t_e_g_e_r a;
   mirror2 := 99999999-a;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e rotate(a);
   _v_a_l_u_e a;
   _i_n_t_e_g_e_r a;
   _b_e_g_i_n
      _i_n_t_e_g_e_r ra,i;

      ra := 0;

      _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
      _b_e_g_i_n
         ra := ra + 10|&(8-(a _m_o_d 10))*i;
         a := a _: 10
      _e_n_d;

      rotate := ra
   _e_n_d rotate;

   _p_r_o_c_e_d_u_r_e testit(row, col);
   _v_a_l_u_e row, col;
   _i_n_t_e_g_e_r row, col;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i, j, testsol, row1, solution;
      _B_o_o_l_e_a_n bad;

      bad := _f_a_l_s_e;
      i := 0;
      _f_o_r i := i+1 _w_h_i_l_e i<row & -, bad _d_o
      _b_e_g_i_n
         row1 := qcolumn[i];
         bad := row1=col Ł row1=col-row+i Ł row1=col+row-i
      _e_n_d _f_o_r;

      _i_f -, bad _t_h_e_n
      _b_e_g_i_n
         qcolumn[row] := col;
         _i_f row=8 _t_h_e_n
         _b_e_g_i_n
            solution := 0;
            _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
            solution := solution*10 + qcolumn[i];
            bad := _f_a_l_s_e;
            j := -1;
            _f_o_r j := j+1 _w_h_i_l_e j_<7 & -, bad _d_o
            _b_e_g_i_n
               testsol := solution;
               _i_f (_B_o_o_l_e_a_n j) _s_h_i_f_t -1 _t_h_e_n testsol := rotate(testsol);
               _i_f (_B_o_o_l_e_a_n j) _s_h_i_f_t -2 _t_h_e_n testsol := mirror1(testsol);
               _i_f (_B_o_o_l_e_a_n j) _s_h_i_f_t -3 _t_h_e_n testsol := mirror2(testsol);
               i := 0;
               _f_o_r i := i+1 _w_h_i_l_e i_<nsol & -, bad _d_o
               _b_e_g_i_n
                  bad := testsol = solutions[i]
               _e_n_d;
            _e_n_d;
            _i_f -, bad _t_h_e_n
            _b_e_g_i_n
               x := (nsol _m_o_d 3)*6;
               y := 21-(nsol _: 3)*6;
               _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
               _b_e_g_i_n
                  plotline(x, y-i*ssize, x+ssize*8, y-i*ssize);
                  plotline(x+i*ssize, y, x+i*ssize, y-8*ssize)
               _e_n_d plot grid;

               _f_o_r i:=1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
               _b_e_g_i_n
                  x := (nsol _m_o_d 3)*6;
                  y := 21-(nsol _: 3)*6;
                  plotchar(40+128, x+(qcolumn[i]-0.75)*ssize, y-(i-0.125)*ssize, ssize*0.75)
               _e_n_d;

               nsol := nsol+1;
               solutions[nsol] := solution
            _e_n_d
         _e_n_d
         _e_l_s_e
         _b_e_g_i_n
            _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
            testit(row+1, i)
         _e_n_d
      _e_n_d
   _e_n_d testit;

   plotline(-78,0,-78,0);
   xxx := 0;

   x := 7;
   y := 25;
   ssize := 5/8;

   plottext(|<<Otte dronninger|>, x, y, 0.3, 0);

   nsol := 0;
   _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 8 _d_o
   testit(1, i);

   slutplot

_e_n_d;
