	    |<<Bitte, schreiben Sie Ihre Initialen hier (Zwischenraum ist Schluss)|>);
	    writetext(|<<: |>);
	    sum := 0;
	    _f_o_r i := lyn _w_h_i_l_e i |= 0 _d_o sum := 64*sum + i;
	    sum := sum - sum_:512*512;
	    _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l sum _d_o RANDOM INTEGER(1)
	 _e_n_d START RANDOM;
	 _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e GROUP SUM;
	 _b_e_g_i_n
