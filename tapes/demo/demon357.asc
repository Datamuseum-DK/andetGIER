	    ASK NUMBER := read integer
	 _e_n_d ASK NUMBER;
	 _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e QUESTION(dan, eng, fr, ger);
	 _s_t_r_i_n_g dan, eng, fr, ger;
	 _b_e_g_i_n
	    _i_n_t_e_g_e_r symb;
      AGAIN:LINE;
	    WRITE TEXT(dan, eng, fr, ger);
