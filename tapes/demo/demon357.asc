      EX:_e_n_d SPECIAL TEST;
	 _b_o_o_l_e_a_n _p_r_o_c_e_d_u_r_e MAN;
	 _b_e_g_i_n
      AA:   actual group := _i_f first _t_h_e_n ASK NUMBER(
