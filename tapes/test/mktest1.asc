slip<
_b a20,b20
i=417
[
    Some simple tests of GIER arithmetics

    MK, 21-Jul-2011
]
;
;    Test 0: Add and subtract without carry
;
b0:  arn a0    , ar  a1    ; R:=  _2_0 0 _2_0 m; R:=R+_2_0 m _2_0 0;
     sr  a0    , sr  a1    ; R:=R-_2_0 0 _2_0 m; R:=R-_2_0 m _2_0 0;
     pi  0                 ; IN:=0;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
;
;    Test 1: Add and subtract with carry
;
     arn a0    , ar  a0    ; R:=  _2_0 0 _2_0 m; R:=R+_2_0 0 _2_0 m;
     ar  a1    , ar  a1    ; R:=R+_2_0 m _2_0 0; R:=R+_2_0 m _2_0 0;
     sr  a0    , sr  a0    ; R:=R-_2_0 0 _2_0 m; R:=R-_2_0 0 _2_0 m;
     sr  a1    , sr  a1    ; R:=R-_2_0 m _2_0 0; R:=R-_2_0 m _2_0 0;
     pi  1                 ; IN:=1;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
;
;    Test 2: Floating add and subtract
;
     arnf a2   , arf a3    ; RF:=   99.0; RF:=RF+9900.0;
     srf  a2   , srf a3    ; RF:=RF-99.0; RF:=RF-9900.0;
     pi   2                ; IN:=2;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
;
;    Test 3: Floating multiplication and divide
;
     arnf a2   , mkf a3    ; RF:=   99.0; RF:=RF*9900.0;
     dkf  a2   , dkf a3    ; RF:=RF/99.0; RF:=RF/9900.0;
     srf  a4               ; RF:=RF-1.0;
     pi   3                ; IN:=3
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
;
;    Test 4: Left short shift
;
     pi  4                 ; IN:=4;
     arn a5                ; R:=2|&0;
     pp  38    , pp  p-1   ; _f_o_r p:=37 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     tk  1                 ; R:=R*2;
     zq                LT  ; _i_f R<0 _t_h_e_n STOP;
     bs  p     , hh  r-3   ; _e_n_d;
     tk  1                 ; R:=2|&39;
     zq                NO  ; _i_f -, spill _t_h_e_n STOP;
     tk  1                 ; R:=2|&40; R00 should be 1, the rest of R zero.
     xr        X           ; This clears R00
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
;
;    Test 5: Right short shift
;
     pi  5                 ; IN:=5;
     arn a6                ; R:=_1 1 _3_9 0;
     pp  39    , pp  p-1   ; _f_o_r p:=38 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     tk  -1                ; R:=R _s_h_i_f_t -1;
     zq                NT  ; _i_f R_>0 _t_h_e_n STOP;
     bs  p     , hh  r-3   ; _e_n_d;
     ar  a5
     zq                NZ  ; _i_f R |= -1 _t_h_e_n STOP;
#072;
;    Test 6: Left short rotate
;
     pi  6                 ; IN:=6;
     arn a5                ; R:=1;
     pp  38    , pp  p-1   ; _f_o_r p:=37 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     ck  1                 ; R:=R _s_h_i_f_t 1;
     zq                LT  ; _i_f R<0 _t_h_e_n STOP;
     bs  p     , hh  r-3   ; _e_n_d;
     ck  1                 ; R:=R _s_h_i_f_t 1;
     zq                NO  ; _i_f -, spill _t_h_e_n STOP;
     ck  1                 ; R:=R _s_h_i_f_t;
     sr  a5                ; 
     zq                NZ  ; _i_f R |= 1 _t_h_e_n STOP;
;
;    Test 7: Right short rotate
;
     pi  7                 ; IN:=7;
     arn a6                ; R:=_1 1 _3_9 0;
     pp  39    , pp  p-1   ; _f_o_r p:=38 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     ck  -1                ; R:=R _s_h_i_f_t -1;
     zq                LT  ; _i_f R<0 _t_h_e_n STOP;
     bs  p     , hh  r-3   ; _e_n_d;
     sr  a5
     zq                NZ  ; _i_f R |= 1 _t_h_e_n STOP;
;
;    Test 8: Left long rotate
;
     pi  8                 ; IN:=8;
     xrn       , arn a5    ; M:=0; R:=1;
     pp  79    , pp  p-1   ; _f_o_r p:=78 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     cl  1                 ; RM:=RM _s_h_i_f_t 1;
     bs  p     , hh  r-2   ; _e_n_d;
     sr  a5                ; R:=R-1;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
     xr                    ; R:=M;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
;
;    Test 9: Right long rotate
;
     pi  9                 ; IN:=9;
     xrn       , arn a5    ; M:=0; R:=1;
     pp  79    , pp  p-1   ; _f_o_r p:=78 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     cl  -1                ; RM:=RM _s_h_i_f_t -1;
     bs  p     , hh  r-2   ; _e_n_d;
     sr  a5                ; R:=R-1;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
     xr                    ; R:=M;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
#072;
;    Test 10: Float/integer
;
     pi  10                ; IN:=10;
     pp  512   , pp  p-1   ; _f_o_r p:=511 _s_t_e_p -1 _u_n_t_i_l 0 _d_o _b_e_g_i_n
     arn p     D           ; Raddr:=p;
     tk  -30   , gr  a7    ; R:=p.39; a7:=R;
     nkf 39    , tkf -29   ; RF:=R; R:=entier(RF);
     sr  a7                ; R:=R-a7;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;
     bs  p     , hh r-6    ; _e_n_d;
     
     pi  1023              ; IN:=1023;
     zq                LKB ; _i_f kbon _t_h_e_n STOP;
     hv  b0                ; Loop back
;
;    Constants:
;
a0:  0/0/1023/1023
a1:  1023/1023/0/0
a2:  6/396/0/0             ; 99.0
a3:  13/309/384/0          ; 9900.0
a4:  0/256/0/0             ; 1.0
a5:  qq  1.39
a6:  qq  1.0
a7:  qq  0
b1:  zq
b2=512
b2:  hv  b0                ; Must be cell 512 for track 0 reader
_eb1


