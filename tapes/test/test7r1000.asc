[444]  qq        IB             ;parameter
[445]  grn  r-25                ;zeroes to cell 44
[446]  arn  r39,gr  r65         ;mge start-random from 109 to 135
[447]  grn  r44                 ;counter:=0
[448]  pp  2,pp  p-1            ;p:=2 , p:=p-1
[449]  grn  p497,hs  r51        ;cell:=0 , go to RAND-2
