[Testprogram no. 8. Test of drump track transfer time.
The time for execution of an LK instruction is tested by the program.If KA
is set to 1, the transfer time for all tracks is printed out.If KA=0 there
will only be output for tracks with a transfer time different from 20 ms.
Th output is in binary notation for the transfer times as well as for the
track numbers.

After the end of a test run ( output <slut> on the typewriter), the test
can be repeated by pressing the NORMAL START-button. If the qq instruction
in location 57 is changed to a zq instruction,the actual transfer time can
after stop in location 57 be observed in the R-register in microseconds
with unit in pos. 19.
First instruction to be executed is zq LKB in location 41.]

[Timing:

clocks: 3053596
steps:  613342
ratio:  20.0858921743413%

Real GIER ratio: 19.74%
]

_b a20,b20
i=41
a1:  zq                LKB ;stop if KB=1
     grn a14
     vy  16    , sy  64    ;select typewriter,CR
     sy  58    , sy  36    ;lower case,m
     sy  18                ;s
a2:  bt  10    t -1        ;write 10 SPACE
     sy        , hv  a2
     sy  19    , sy  41    ;t,r
     sy  49    , sy  51    ;a,c
     sy  34    , sy  64    ;k,CR
a3:  bt  320   t -1        ;select -
a11: vk  -1    Vt 1        ;- tracks 0-319
     hv  a4                ;go to 75 if track no. =319
     lkn -512              ;read track, zeroes to R
a5:  hk  a6                ;if transfer finished the go to 57 -
     ar  a7                ;else add 113 microseconds
     hv  a5                ;and go to 54
a6:  qq                    ;empty nkf 9
     gr  a15
     nkf 9     , arf a14
     grf a14
     arn a15
     nc  20            NKA ;output for all tracks if KA=1 -
     qq        V           ;- else only output for tracks -
     hv  a3                ; - with transfer time |= 20 ms
     nkf 9                 ; RF:=time
     qq  a13   , hs  b5    ; write(|<ddd.dd|>,time);
     arn (a11) D           ; Raddr:=track
     qq  a12   , hs  b1    ; write(|<dddd|>,track);
     sy  64                ;CR
     hv  a3                ;go to new track
a7:  qq        t 113       ;number of microseconds
a4:  arnf a14  , dkf a16   ; RF:=sum/320;
     qq  a13   , hs  b5    ; write(|<ddd.dd|>,average);
     sy  64    , sy  18    ;s
     sy  35    , sy  20    ;l,u
     sy  19    , sy  64    ;t,CR
     zq                    ;stop
     pa  a2    t 10        ;reset loc. 45
     pa  a3    t 320       ;reset loc. 50
     pa  a11   t -1        ;reset loc. 51
     hv  a1                ;go to start
a12: qq  4.3+4.7+1.14+4.23 ; |<dddd|>
a13: qq  5.3+3.7+2.13+1.14+3.23+2.27 ; |<ddd.dd|>
a14: qq ; average
a15: qq ; temp
a16: _f 320.0

