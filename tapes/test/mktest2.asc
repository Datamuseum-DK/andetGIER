[
    mktest2

    Some simple tests of GIER arithmetics

    MK, 21-Jul-2011
]
;
;    Test 3: Floating multiplication and divide
;
b0:  arnf a0               ; RF:=99.0;
     grf a3                ; a3:=99.0;
     mkf a1                ; RF:=RF*9900.0;
     grf a4                ; a4:=99.0*9900.0;
     dkf a0                ; RF:=RF/99.0;
     grf a5                ; a5:=99.0*9900.0/99.0;
     dkf a1                ; RF:=RF/9900.0;
     grf a6                ; a6:=99.0*9900.0/99.0/9900.0;
     srf a2                ; RF:=RF-1.0;
     grf a7                ; a7:=99.0*9900.0/99.0/9900.0-1.0;
     pi   3                ; IN:=3;
     zq                NZ  ; _i_f R |= 0 _t_h_e_n STOP;

     pi  1023              ; IN:=1023;
     zq                LKB ; _i_f kbon _t_h_e_n STOP;
     hv  b0                ; Loop back
;
;    Constants:
;
a0:  6/396/0/0             ; 99.0
a1:  13/309/384/0          ; 9900.0
a2:  0/256/0/0             ; 1.0
a3:  qq                    ; 99.0
a4:  qq                    ; 99.0*9900.0 = 980100.0
a5:  qq                    ; 99.0*9900.0/99.0 = 9900.0
a6:  qq                    ; 99.0*9900.0/99.0/9900.0 = 1.0
a7:  qq                    ; 99.0*9900.0/99.0/9900.0-1.0 = 0.0
b1:  zq
