                                                                      
[29 jan. 1963]

                    [THE GIER ALGOL COMPILER]

                [Definition of storage of compiler]

_b c100, e100             ; Begin of outermost block

_d c70=39                 ; First track during loading of compiler

_d c60=39                 ; After loading the compiler will be moved to have
                         ;       its first track in c60

_d e85=0                  ; Reserve e85 tracks after standard procedures

_d e86=0                  ; Reserve e86 tracks after top of translator

_d e20=318                ; Last track -1

_s                        ; Allows manual redefinition of c70,c60,e85,e86 and e20

_d e70=c70-c60            ; Resulting displacement of translator

_d e13=i+39               ; First core cell +39

_d e25=983                ; Last core cell -40

_d e4=e13+194             ; Place for universal translator parameters

              
_s                                                                                                      
_bk=c60+e70,i=822,a30,b20
_dc61=c60
_dc=6


