slip<
i=41
     zq                LKB ; stop if KB
     zq                NKB ; stop if not KB
     vy                    ; choose reader
     pm  127   D           ; set mask for bits 3-9
     pp  1023              ; set first character to -1
     lyn r-4   , pp  p+1   ; read, add 1 to p
     cm  p     D           ; compare
     zq                    ; error stop
     hv  r-3               ; jump
_e41

