Program d-353.  Test of FIT1.
_b_e_g_i_n
   _i_n_t_e_g_e_r i;
   _r_e_a_l A, B, mean error, mean2, ycal, error;
   _a_r_r_a_y X, Y[1: 13];
   _c_o_p_y FIT1<
   select(17);
   writetext(|<<
Read input to d-353:|>);
   lyn;
   select(8);
   _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 13 _d_o
   _b_e_g_i_n
      X[i] := read real;
      Y[i] := read real;
   _e_n_d for i;
   FIT1(13, mean error, A, B, X, Y);
   writetext(|<<
Output d-353
     X  YOBS  YCAL  ERROR
|>);
   mean2 := 0;
   _f_o_r i := 1 _s_t_e_p 1 _u_n_t_i_l 13 _d_o
   _b_e_g_i_n
      ycal := A + B*X[i];
      error := ycal - Y[i];
      writecr;
      write(|<-ddddd|>, X[i], Y[i], ycal, error);
      mean2 := mean2 + error|&2;
   _e_n_d for i;
   writecr;
   writetext(|<<    A           B         mean error  mean2|>);
   writecr;
   write(|<-dddd.dddd00|>, A, B, mean error, sqrt(mean2/12));
   writecr;
_e_n_d;
