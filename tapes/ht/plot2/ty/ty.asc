algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r ty;
   _r_e_a_l a,b,x0,y0,xol,yol,r2,f,t,ff;
   _p_r_o_c_e_d_u_r_e PCURVE(x, y, t, t1, t2, n, type);
   _v_a_l_u_e t1, t2, n, type;
   _i_n_t_e_g_e_r n, type;
   _r_e_a_l x, y, t, t1, t2;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i, ty;
      ty := 0;
      _i_f n < 1 _t_h_e_n n := 1;
      _f_o_r i := 0 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _b_e_g_i_n
         t := (t1*(n-i) + t2*i)/n;
	 writecr;
	 write(|<-dddddd.dddd|>, x, y);
         ty := type
      _e_n_d
   _e_n_d PCURVE;
   select(32);
   _f_o_r ty := 2 _s_t_e_p 1 _u_n_t_i_l 5 _d_o
   _b_e_g_i_n
      writecr;
      writetext(|<<ty: |>);
      write(|<dd|>,ty);
      writecr;
      a := 0;
      b := 0;
      x0 := 1;
      y0 := 0;
      xol := 0;
      yol := 1;
      r2 := (x0-a)|&2 + (y0-b)|&2;
      f := _i_f ty = 3 £ ty = 4 _t_h_e_n -1 _e_l_s_e 1;
      _i_f ty < 4 _t_h_e_n
      PCURVE(t, b + sqrt(abs(r2 - (t-a)|&2))*f, t, xol, x0,
      50*abs(xol-x0), 1) _e_l_s_e
      _b_e_g_i_n
	 ff := _i_f y0 > yol _t_h_e_n -1 _e_l_s_e 1;
	 PCURVE(t, b + sqrt(abs(r2-(t-a)|&2))*ff, t, xol,
	 a + sqrt(r2)*f, 50*abs(xol-a-sqrt(r2)*f), 1);
	 PCURVE(t, b-sqrt(abs(r2-(t-a)|&2))*ff, t,
	 a + sqrt(r2)*f, x0, 50*abs(a + sqrt(r2)*f - x0), 1)
      _e_n_d;
      xol := x0;
      yol := y0
   _e_n_d ty
_e_n_d;
t<

