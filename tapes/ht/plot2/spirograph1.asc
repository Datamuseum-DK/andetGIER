algol<
_b_e_g_i_n
   _b_o_o_l_e_a_n plot;
   _i_n_t_e_g_e_r xxx, yyy, xx, yy;
   _r_e_a_l deltax, deltay, t, r, R, rho, k, l;
   _c_o_r_e _c_o_d_e plot, xx, yy;
   2, 46;
   1, 44;
   1, 44;
   gs     re5 , ps   (b2)  ;  s := display reference
   xrn      0 , ann   sa2  ;  M := 0, R := abs(xx)
   sn     sa3 , cl      1  ;  - abs(yy)
   arn    sa2 , cl      1  ;  xx
   arn    sa3 , cl      1  ;  yy
   cln     -8 , ga    re6  ;  store bit*4
   arn    re7 , pm    re8  ;  fetch parameters
e6:cl       _0 , mb    re1  ;  move bits
   gaX    re3              ;  store straight step
   mb     re1 , ga    re4  ;  store diagonally step
   annX   sa2              ;  M := abs(xx)
   ann    sa3 , tl      1  ;  R := abs(yy), M := M*2, R := R*2
   bs   (re6) t +12        ;  shift M and R
   xr       0              ;  if abs(yy) > abs(xx)
   gr     sa3 , gm    sa2  ;  store yy and xx
   srn    sa2 , tl     -1  ;  test := - xx_:2
e2:hv     re1 , ar    sa3  ;  test := test + yy
e3:syV      _0          LT  ;  straight step
e4:sy       _0 , sr    sa2  ;  diagonally step
e1:xr      15 , sr    c42  ;  xx := xx - 1
   hhX    re2          NT  ;  xx _> 0
e5:ps       _0 , hr     s1  ;  exit
e7:qq  4.9+4.13+ 2.17+2.21+ 8.25+1.29+ 8.33+1.37  ;  parameter 1
e8:qq 12.9+5.13+10.17+3.21+12.25+5.29+10.33+3.37  ;  parameter 2
   _e;
   _p_r_o_c_e_d_u_r_e plotcurve(x,y,t,t1,t2,n);
   _v_a_l_u_e t1,t2,n;
   _r_e_a_l x,y,t,t1,t2;
   _i_n_t_e_g_e_r n;
   _b_e_g_i_n
      _i_n_t_e_g_e_r i,s;
      _r_e_a_l x0,y0;
      _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l n _d_o
      _b_e_g_i_n
         t := (t1*(n-i) + t2*i)/n;
	 xx := x/deltax - xxx;
	 yy := y/deltay - yyy;
	 xxx := xxx+xx;
	 yyy := yyy+yy;
         s:=select(64);
	 _i_f i=0 _t_h_e_n
	 _b_e_g_i_n
	    x0 := x;
	    y0 := y;
	    writechar(16);
	 _e_n_d
	 _e_l_s_e
	 _i_f i=1 _t_h_e_n
	 writechar(32);
	 gier(plot);
         select(32);
	 writecr;
	 write(|<dddddd|>, i);
	 write(|<-dd.dddddd|>, t, x, y, sqrt((x-x0)|&2+(y-y0)|&2));
	 select(s)
      _e_n_d i
   _e_n_d plotcurve;
   select(17);
   xxx := yyy := 0;
   deltax := deltay := 0.01;
   R := 27.02;
   r := 13.4;
   rho := 10;
   l := rho/r;
   k := r/R;
   plotcurve(
   R*((1-k)*cos(t)+l*k*cos((1-k)/k*t)),
   R*((1-k)*sin(t)-l*k*sin((1-k)/k*t)),t,0,3.14159265*1600,80000)
_e_n_d;
