Program d-404. Test of OPT1B with two variables.
_b_e_g_i_n
   _i_n_t_e_g_e_r COUNT1, COUNT2, EVAL, STATE1, STATE2;
   _r_e_a_l tinlet, ginlet, Y1, Y2, delt, delg;
   _a_r_r_a_y XOLD1, XOLD2, Y1OLD1, Y1OLD2, Y2OLD1, Y2OLD2[1:4];
   _c_o_p_y POL <
   _c_o_p_y OPT1B <
   _p_r_o_c_e_d_u_r_e PRINT;
   _b_e_g_i_n
      writecr;
      write(|<dddddd|>, EVAL, tinlet, ginlet);
      writetext(|<<   |>);
      write(|<-ddd.dd|>, Y1, Y2)
   _e_n_d PRINT;
   select(8);
   writetext(|<<
Output d-404

  eval  tinlet  ginlet  PROD   EXCESS
|>);
   EVAL := 0;
   COUNT1 := 0;
   tinlet := 400;
