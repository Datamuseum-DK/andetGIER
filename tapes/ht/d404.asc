   _i_f STATE2 = 0 _t_h_e_n _g_o_ _t_o A2;
   STATE1 := OPT1B(COUNT1, tinlet, Y1, Y2, 380, 460, delt,
   XOLD1, Y1OLD1, Y2OLD1, tinlet, Y1, Y2);
   _i_f STATE1 = 0 _t_h_e_n
   _b_e_g_i_n
      ginlet := ginlet - 2;
      _g_o_ _t_o A1
   _e_n_d STATE1;
