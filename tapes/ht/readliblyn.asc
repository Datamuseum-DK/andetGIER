algol,_n<
Program READLIB. Copy library to disc. Buffer version.
Using lyn instead of read string, remove blanks outside text strings.
_b_e_g_i_n
   _i_n_t_e_g_e_r n, p, r, i, place, free area, status, case, state, cell, shift;
   _b_o_o_l_e_a_n _a_r_r_a_y NAME, BUFFER[0:39];
   _b_o_o_l_e_a_n code1, char2, mask;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e p step;
   _b_e_g_i_n
      p step := p;
      p := p + 1
   _e_n_d;
   _c_o_r_e _c_o_d_e code1,NAME;
   2, 46;
   2, 50;
   arn a2,gr re2
   it re1, pa re4
e3: arn re2, il 0
    arn c17
e4: gr _0 t1 X M
   xrn, cl -6
   ca 10,hv re5
