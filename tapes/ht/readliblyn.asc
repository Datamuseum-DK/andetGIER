_e;

   _c_o_m_m_e_n_t Read filename, ending at CR;

   select(16);
AGAIN:
   char := lyn;
   _i_f char |= 58 & char |= 60 & 
      (char < 18 È char > 25) &
      (char < 33 È char > 41) &
      char |= 43 &
      (char < 48 È char > 57) _t_h_e_n _g_o_ _t_o AGAIN;
   n := 0;
   r := read string(NAME, _1_0 384 _1_0 384 _1_0 384 _3 2 _7 64, n);

   _i_f r = -1 _t_h_e_n
   _b_e_g_i_n
      writetext(|<<Error reading filename.|>);
      writecr;
      _g_o_ _t_o ZZ
   _e_n_d;

   writecr;
   p := 0;
   writetext(_s_t_r_i_n_g NAME[p step]);
   writetext(|<<: |>);

   p := 0;
   status := cancel(_s_t_r_i_n_g NAME[p step]);
   _i_f status=0 _t_h_e_n
   writetext(|<<Replace: |>)
   _e_l_s_e _i_f status=1 _t_h_e_n
   writetext(|<<New: |>)
   _e_l_s_e
   _b_e_g_i_n
      writecr;
      writetext(|<<Error during cancel: |>);
      writeinteger(|<p|>,status)
   _e_n_d cancel error;

   status := where(|<<free|>, free area);
   _i_f status |= 0 _t_h_e_n
   _b_e_g_i_n
      writetext(|<<where of free area failed.|>);
      writecr;
      _g_o_ _t_o ZZ
   _e_n_d;

   place := n := char := case := state := 0;
   r := -1;
   _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 39 _d_o
   BUFFER[i]:=_4 10 _6 10 _6 10 _6 10 _6 10 _6 10 _6 10;

   _c_o_m_m_e_n_t
     state:
         0: Before anything
	 1: after |
	 2: after |<
	 3: after |< |
	 ;
next char:
   char := lyn+case;
   _i_f char=60 È char=188 _t_h_e_n
   case:=128
   _e_l_s_e _i_f char=58 È char=186 _t_h_e_n
   case:=0
   _e_l_s_e _i_f char=142 _t_h_e_n
   _b_e_g_i_n
      _i_f state=0 È state=2 _t_h_e_n state:=state+1
   _e_n_d 
   _e_l_s_e _i_f char=17 _t_h_e_n
   _b_e_g_i_n
      _i_f state=1 _t_h_e_n state:=2
   _e_n_d
   _e_l_s_e _i_f char=145 _t_h_e_n
   _b_e_g_i_n
      _i_f state=3 _t_h_e_n state:=0
   _e_n_d
   _e_l_s_e _i_f state=1 È state=3 _t_h_e_n state:=state-1;
   _i_f (char|=0 & char|=128) È state=2 _t_h_e_n
   _b_e_g_i_n
      _i_f n_>240 _t_h_e_n
      _b_e_g_i_n
         place:=place+1;
	 put(BUFFER, free area, place);
	 _f_o_r i:=0 _s_t_e_p 1 _u_n_t_i_l 39 _d_o
	 BUFFER[i]:=_4 10 _6 10 _6 10 _6 10 _6 10 _6 10 _6 10;
	 n:=0
      _e_n_d;
      cell := n_:6;
      shift := (n _m_o_d 6)*6;
      mask := -,(_3_4 0 _6 m _s_h_i_f_t shift);
      char2 := (_b_o_o_l_e_a_n char) & _3_4 0 _6 m;
      _i_f char=64 È char=192 _t_h_e_n char2 := _3_4 0 _6 m;
      BUFFER[cell]:=(BUFFER[cell] & mask) È (char2 _s_h_i_f_t shift);
      _i_f shift=30 _t_h_e_n
      BUFFER[cell]:=(BUFFER[cell] & _4 0 _3_6 m) È _4 15 _3_6 0;
      n:=n+1
   _e_n_d pack character;
   _i_f char|=11 & char|=12 & char|=139 & char|=140 _t_h_e_n _g_o_t_o next char;

   _i_f n>0 _t_h_e_n
   _b_e_g_i_n
      place:=place+1;
      put(BUFFER, free area, place)
   _e_n_d;

   p := 0;
   status := reserve(_s_t_r_i_n_g NAME[p step], place);

   _i_f status |= 0 _t_h_e_n
   _b_e_g_i_n
      writetext(|<<Reserve of area failed. Error code: |>);
      write integer(|<ddd|>, status);
      writecr;
      writetext(|<<place: |>);
      write integer(|<p|>, place);
      writecr;
      _g_o_ _t_o ZZ
   _e_n_d;

   _c_o_m_m_e_n_t call setsum,NAME< ;
   gier(code1);

   writeinteger(|<p|>, place);
   writetext(|<< block|>);
   _i_f place|=1 _t_h_e_n writetext(|<<s|>);
   writetext(|<<.|>);

   _i_f char=11 _t_h_e_n _g_o_ _t_o AGAIN;
ZZ:
_e_n_d;
