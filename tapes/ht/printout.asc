algol<
_b_e_g_i_n
   _i_n_t_e_g_e_r n, p, r, i, place, area, status, case, state, cell, shift;
   _b_o_o_l_e_a_n _a_r_r_a_y NAME, BUFFER[0:39];
   _b_o_o_l_e_a_n code1, char2, mask;
   _i_n_t_e_g_e_r _p_r_o_c_e_d_u_r_e p step;
   _b_e_g_i_n
      _i_f p=40 _t_h_e_n
      _b_e_g_i_n
         place := place+1;
	 get(BUFFER, area, place);
	 p := 0
      _e_n_d next track;
      p step := p;
      p := p + 1
   _e_n_d;

   _c_o_m_m_e_n_t Read filename, ending at CR;

   select(9);
AGAIN:
   char := lyn;
   _i_f char |= 58 & char |= 60 & 
      (char < 18 Ł char > 25) &
      (char < 33 Ł char > 41) &
      char |= 43 &
      (char < 48 Ł char > 57) _t_h_e_n _g_o_ _t_o AGAIN;
   n := 0;
   r := read string(NAME, _1_0 384 _1_0 384 _1_0 384 _3 2 _7 64, n);

   _i_f r = -1 _t_h_e_n
   _b_e_g_i_n
      writetext(|<<Error reading filename.|>);
      writecr;
      _g_o_ _t_o ZZ
   _e_n_d;

   writecr;
   p := 0;
