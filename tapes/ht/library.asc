   T2[2] := 2541;
   T2[3] := 1352;
   T2[4] := 1511;
   T3[1] := 44848886;
   T3[2] := 88888888;
   T3[3] := 44882288;
   T3[4] := 28882837;
   T3[5] := T3[6] := T3[7] := T3[8] := 88888888;
   T3[9] := 22818886;
   T3[10] := 88888888;
   T3[11] := 22882288;
   T3[12] := 28882837;
   T3[13] := 52818886;
   T3[14] := 88888888;
   T3[15] := 52885288;
   T3[16] := 58885857;
   XOLD[1] := X;
   Y1OLD[1] := Y1;
   Y2OLD[1] := Y2;
