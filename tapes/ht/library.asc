      +4*NEG(Y1OLD[3]-Y1OLD[4]) + 8*NEG(Y1OLD[2]-Y1OLD[3]);
      COL := 1 + NEG(Y2OLD[4]) + 2*NEG(Y2OLD[3]) + 4*NEG(Y2OLD[2]);
      I := T3[ROW];
