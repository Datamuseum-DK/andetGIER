EX:COUNT := COUNT + 1;
_e_n_d OPT1B;
_f_i_n_i_s
#011DIRSEARCH
_p_r_o_c_e_d_u_r_e DIRSEARCH(VAR, XACT, DELSTART, eps, REDFAC, FUNC,
signfactor, FACT, maxev, conv);
_v_a_l_u_e VAR, signfactor;
_b_o_o_l_e_a_n conv;
_i_n_t_e_g_e_r VAR, signfactor, maxev;
