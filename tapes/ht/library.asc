UP:   X := X + DELX;
   _e_n_d COUNT = 0 _e_l_s_e
   _i_f COUNT = 1 _t_h_e_n
   _b_e_g_i_n
      MOVE(1, 3);
      ROW := 1 + NEG(Y2OLD[2]-Y2OLD[3]) + 2*NEG(Y1OLD[2]-Y1OLD[3]);
      COL := 1 + NEG(Y2OLD[3]) + 2*NEG(Y2OLD[2]);
