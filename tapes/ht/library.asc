      Y1OPT := Y1OLD[I];
      Y2OPT := Y2OLD[I];
      _g_o_ _t_o EX;
D1:   _g_o_ _t_o _i_f XOLD[2] - abs (DELX) _> XMIN _t_h_e_n DN _e_l_s_e S1;
DE:   _g_o_ _t_o _i_f XOLD[2] - abs (DELX) _> XMIN _t_h_e_n DN _e_l_s_e ER;
U3:   _g_o_ _t_o _i_f DELX < 0 _t_h_e_n ER _e_l_s_e _i_f XOLD[4] + DELX_<XMAX
      _t_h_e_n L1 _e_l_s_e S3;
UE:   _i_f DELX < 0 _t_h_e_n _g_o_ _t_o ER;
      _i_f XOLD[4] + DELX > XMAX _t_h_e_n _g_o_ _t_o ER;
L1:   MOVE(3,2);
      MOVE(4,3);
